        },
        {
          "key": "year",
          "label": "原作年份",
          "value": "約 1951",
          "sourceUrl": "https://hymnary.org/text/father_long_before_creation",
          "sourceLabel": "hymnary.org"
        },
        {
          "key": "background",
          "label": "背景故事摘要",
          "value": "這首聖詩原為中國基督徒所使用的無名作品，據記載於1952至1953年間在北京一個查經聚會中傳唱，後由曾在中國宣教的 Francis P. Jones 翻譯成英文，並於1953年發表，之後被收錄於多本聖詩集。詩歌背景與中國共產政權早期對宗教的限制有關，因此其信仰宣告更顯堅定。",
          "sourceUrl": "https://hymnary.org/text/father_long_before_creation",
          "sourceLabel": "hymnary.org"
        },
        {
          "key": "scripture",
          "label": "相關經文",
          "value": "約翰福音 3:16；以弗所書 1:4",
          "sourceUrl": "https://hymnary.org/text/father_long_before_creation",
          "sourceLabel": "hymnary.org"
        }
      ],
      "allSources": [
        "https://hymnary.org/text/father_long_before_creation"
      ]
    },
