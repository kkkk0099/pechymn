---
import BaseLayout from '../layouts/BaseLayout.astro';

const buildVersion = import.meta.env.PUBLIC_BUILD_VERSION || __APP_BUILD_VERSION__;
const baseUrl = import.meta.env.BASE_URL;
const toBase = (path = '') => `${baseUrl}${String(path).replace(/^\/+/, '')}`;
---

<BaseLayout title="平安詩集" description="平安詩集 Sprint 2：全文搜尋與按需載入歌詞。">
	<div id="top-controls-overlay" class="top-controls-overlay" aria-label="搜尋與分類控制">
		<div class="top-controls-overlay-card card panel">
			<div class="search-row">
				<input id="search-input" class="search-input" type="search" placeholder="歌曲編號 / 歌詞內容" autocomplete="off" />
				<button id="search-btn" type="button" class="search-btn" aria-label="搜尋" title="搜尋">🔍</button>
				<button id="toggle-settings" type="button" class="search-btn subtle" aria-label="設定" title="設定">
					<svg class="settings-btn-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
						<path d="M19.14 12.94a7.96 7.96 0 0 0 .06-.94 7.96 7.96 0 0 0-.06-.94l2.03-1.58a.5.5 0 0 0 .12-.64l-1.92-3.32a.5.5 0 0 0-.6-.22l-2.39.96a7.46 7.46 0 0 0-1.63-.94l-.36-2.54A.5.5 0 0 0 13.9 2h-3.8a.5.5 0 0 0-.49.42l-.36 2.54a7.46 7.46 0 0 0-1.63.94l-2.39-.96a.5.5 0 0 0-.6.22L2.71 8.48a.5.5 0 0 0 .12.64l2.03 1.58a7.96 7.96 0 0 0-.06.94c0 .32.02.63.06.94l-2.03 1.58a.5.5 0 0 0-.12.64l1.92 3.32a.5.5 0 0 0 .6.22l2.39-.96c.5.38 1.05.7 1.63.94l.36 2.54a.5.5 0 0 0 .49.42h3.8a.5.5 0 0 0 .49-.42l.36-2.54c.58-.24 1.13-.56 1.63-.94l2.39.96a.5.5 0 0 0 .6-.22l1.92-3.32a.5.5 0 0 0-.12-.64l-2.03-1.58zM12 15.2A3.2 3.2 0 1 1 12 8.8a3.2 3.2 0 0 1 0 6.4z"></path>
					</svg>
				</button>
				<div id="search-history-overlay" class="search-history-overlay" aria-hidden="true">
					<div id="search-history-list" class="search-history-list"></div>
				</div>
			</div>

			<select id="group-list" class="group-select" aria-label="分類選單"></select>

			<div id="settings-panel" class="settings-panel">
				<div class="settings-grid">
					<label>
						<span id="label-font-size">字體大小</span>
						<input id="setting-font-size" type="range" min="16" max="70" step="1" value="23" />
					</label>
					<label>
						<span id="label-language">語言</span>
						<select id="setting-language">
							<option value="big5">繁體</option>
							<option value="gb">簡體</option>
						</select>
					</label>
					<label class="congregation-setting">
						<span id="label-congregation">堂會</span>
						<div id="setting-congregation" class="congregation-options" role="radiogroup" aria-label="堂會">
							<label class="congregation-option">
								<input type="radio" name="setting-congregation" value="other" checked />
								<span id="label-congregation-other">其他堂會</span>
							</label>
							<label class="congregation-option">
								<input type="radio" name="setting-congregation" value="kp_yp" />
								<span id="label-congregation-kpyp">葵平/涌平</span>
							</label>
							<label class="congregation-option">
								<input type="radio" name="setting-congregation" value="sht" />
								<span id="label-congregation-sht">沙平</span>
							</label>
						</div>
					</label>
				</div>
				<button id="settings-close" type="button" class="settings-close" aria-label="關閉設定">關閉</button>
			</div>
		</div>
	</div>

	<!-- Congregation prompt shown on first visit -->
	<div id="congregation-prompt" class="congregation-prompt hidden" aria-hidden="true">
		<div class="congregation-prompt-label">你所屬的堂會是：</div>
		<div class="congregation-prompt-actions">
			<button type="button" data-congreg="other" class="congregation-prompt-btn">其他堂會</button>
			<button type="button" data-congreg="kp_yp" class="congregation-prompt-btn">葵平/涌平</button>
			<button type="button" data-congreg="sht" class="congregation-prompt-btn">沙平</button>
		</div>
	</div>

	<section class="search-layout" id="hymn-app">
		<article class="card panel search-panel">
			<div id="result-list" class="result-list" aria-live="polite"></div>
		</article>
	</section>

	<div id="floating-quickbar" class="floating-quickbar" aria-label="快捷列">
		<div id="quickbar-collections" class="quickbar-collections"></div>
		<button id="quickbar-bookmark" type="button" class="quickbar-bookmark">
			<svg class="quickbar-bookmark-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
				<path d="M6 3h12a1 1 0 0 1 1 1v17l-7-4-7 4V4a1 1 0 0 1 1-1z"></path>
			</svg>
			<span>書籤</span>
		</button>
		<button id="quickbar-search" type="button" class="quickbar-search" aria-label="搜索" title="搜索">
			<svg class="quickbar-search-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
				<path d="M11 4a7 7 0 1 1 0 14 7 7 0 0 1 0-14zm0-2a9 9 0 1 0 5.65 16.02l4.16 4.16 1.41-1.41-4.16-4.16A9 9 0 0 0 11 2z"></path>
			</svg>
			<span>搜索</span>
		</button>
	</div>

	<div id="bookmark-overlay" class="bookmark-overlay hidden-panel" aria-hidden="true">
		<div class="bookmark-overlay-card" role="dialog" aria-modal="true" aria-label="書籤與瀏覽記錄">
			<button id="bookmark-overlay-close" type="button" class="bookmark-overlay-close" aria-label="關閉視窗">
				<svg class="close-btn-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
					<path d="M5 5L19 19M19 5L5 19"></path>
				</svg>
			</button>
			<div class="shelf-grid overlay-shelf-grid">
				<section class="shelf">
					<h3 id="bookmark-title">我的書籤</h3>
					<div id="bookmark-list" class="shelf-list"></div>
				</section>
				<section class="shelf">
					<h3 id="history-title">瀏覽記錄</h3>
					<div id="history-list" class="shelf-list"></div>
				</section>
			</div>
		</div>
	</div>

	<div id="lyric-overlay" class="lyric-overlay hidden-panel" aria-hidden="true">
		<div class="lyric-overlay-card" role="dialog" aria-modal="true" aria-label="歌詞視窗">
			<button id="lyric-overlay-close" type="button" class="lyric-overlay-close" aria-label="關閉視窗">
				<svg class="close-btn-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
					<path d="M5 5L19 19M19 5L5 19"></path>
				</svg>
			</button>
			<div id="lyric-viewer" class="lyric-viewer" data-current-id="">
				<div class="empty-state">請先在左側搜尋並點選一首詩歌。</div>
			</div>
			<div id="song-info-dialog" class="song-info-dialog hidden-panel" aria-hidden="true">
				<div class="song-info-card" role="dialog" aria-modal="true" aria-label="歌曲資料">
					<button id="song-info-close" type="button" class="song-info-close" aria-label="關閉歌曲資料視窗">
						<svg class="close-btn-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
							<path d="M5 5L19 19M19 5L5 19"></path>
						</svg>
					</button>
					<h3 id="song-info-title" class="song-info-title"></h3>
					<div id="song-info-content" class="song-info-content"></div>
				</div>
			</div>
		</div>
	</div>

	<script src={`${toBase('langConvert.js')}?v=${buildVersion}`} is:inline></script>
	<script type="module" is:inline define:vars={{ baseUrl }}>
		const STORAGE_KEY = 'hymn_app_state_v2';
		const STATE_VERSION = 2;
		const APP_BASE_URL = String(baseUrl || '/');
		const toBasePath = (path = '') => `${APP_BASE_URL}${String(path).replace(/^\/+/, '')}`;
		const isBrowserSupported =
			typeof Promise === 'function' &&
			typeof fetch === 'function' &&
			typeof Map === 'function' &&
			typeof localStorage !== 'undefined' &&
			typeof document.querySelector === 'function' &&
			typeof String.prototype.normalize === 'function';

		if (!isBrowserSupported) {
			if (typeof window.__activateLegacyFallback === 'function') {
				window.__activateLegacyFallback();
			}
			throw new Error('Unsupported browser, redirected to /v2.');
		}
		const FONT_SIZE_MIN = 16;
		const FONT_SIZE_MAX = 70;
		const FONT_SIZE_AUTO_MAX = 60;
		const FONT_SIZE_ANCHORS_TOUCH = [
			{ width: 320, size: 20 },
			{ width: 375, size: 23 },
			{ width: 425, size: 26 },
			{ width: 768, size: 34 },
		];
		const FONT_SIZE_ANCHORS_LAPTOP = [
			{ width: 320, size: 20 },
			{ width: 375, size: 23 },
			{ width: 425, size: 26 },
			{ width: 768, size: 50 },
		];
		const QUICKBAR_EDGE_PADDING = 20;
		const QUICKBAR_COLLECTIONS_MIN_WIDTH = 170;
		const SEARCH_HISTORY_MAX = 6;
		const LEGACY_SHELF_MAX = 20;
		const CONGREGATION_OTHER = 'other';
		const CONGREGATION_KP_YP = 'kp_yp';
		const CONGREGATION_SHT = 'sht';
		const CONGREGATION_HASH_KP_YP = 'kwcskc';
		const CONGREGATION_HASH_KP = 'kwc';
		const CONGREGATION_HASH_SKC = 'skc';
		const CONGREGATION_HASH_SHT = 'sht';

		function interpolateResponsiveFontSize(width, anchors) {
			if (!Array.isArray(anchors) || anchors.length < 2) return 23;
			const x = Number.isFinite(width) ? width : 375;

			for (let i = 0; i < anchors.length - 1; i += 1) {
				const a = anchors[i];
				const b = anchors[i + 1];
				if (x >= a.width && x <= b.width) {
					const ratio = (x - a.width) / (b.width - a.width);
					return a.size + (b.size - a.size) * ratio;
				}
			}

			if (x < anchors[0].width) {
				const a = anchors[0];
				const b = anchors[1];
				const ratio = (x - a.width) / (b.width - a.width);
				return a.size + (b.size - a.size) * ratio;
			}

			const a = anchors[anchors.length - 2];
			const b = anchors[anchors.length - 1];
			const ratio = (x - a.width) / (b.width - a.width);
			return a.size + (b.size - a.size) * ratio;
		}

		function getResponsiveDefaultFontSize() {
			const viewportWidth = Math.max(window.innerWidth || 0, document.documentElement?.clientWidth || 0);
			const isLaptopLike =
				viewportWidth >= 768 && window.matchMedia('(hover: hover) and (pointer: fine)').matches;
			const anchors = isLaptopLike ? FONT_SIZE_ANCHORS_LAPTOP : FONT_SIZE_ANCHORS_TOUCH;
			const interpolated = interpolateResponsiveFontSize(viewportWidth, anchors);
			return Math.min(FONT_SIZE_AUTO_MAX, Math.max(FONT_SIZE_MIN, Math.round(interpolated)));
		}

		const input = document.getElementById('search-input');
		const searchRow = document.querySelector('.search-row');
		const searchBtn = document.getElementById('search-btn');
		const searchHistoryOverlay = document.getElementById('search-history-overlay');
		const searchHistoryList = document.getElementById('search-history-list');
		const toggleSettingsBtn = document.getElementById('toggle-settings');
		const settingsPanel = document.getElementById('settings-panel');
		const settingsCloseBtn = document.getElementById('settings-close');
		const settingFontSize = document.getElementById('setting-font-size');
		const settingLanguage = document.getElementById('setting-language');
		const fontSizeLabel = document.getElementById('label-font-size');
		const languageLabel = document.getElementById('label-language');
		const congregationLabel = document.getElementById('label-congregation');
		const congregationOtherLabel = document.getElementById('label-congregation-other');
		const congregationKpypLabel = document.getElementById('label-congregation-kpyp');
		const congregationShtLabel = document.getElementById('label-congregation-sht');
		const congregationRadioOptions = Array.from(document.querySelectorAll('input[name="setting-congregation"]'));
		const hymnApp = document.getElementById('hymn-app');
		const topControlsOverlay = document.getElementById('top-controls-overlay');
		const floatingQuickbar = document.getElementById('floating-quickbar');
		const resultList = document.getElementById('result-list');
		const groupList = document.getElementById('group-list');
		const quickbarCollections = document.getElementById('quickbar-collections');
		const quickbarBookmark = document.getElementById('quickbar-bookmark');
		const quickbarSearch = document.getElementById('quickbar-search');
		const bookmarkOverlay = document.getElementById('bookmark-overlay');
		const bookmarkOverlayClose = document.getElementById('bookmark-overlay-close');
		const lyricOverlay = document.getElementById('lyric-overlay');
		const lyricOverlayClose = document.getElementById('lyric-overlay-close');
		const lyricOverlayCard = lyricOverlay ? lyricOverlay.querySelector('.lyric-overlay-card') : null;
		const bookmarkList = document.getElementById('bookmark-list');
		const historyList = document.getElementById('history-list');
		const lyricViewer = document.getElementById('lyric-viewer');
		const songInfoDialog = document.getElementById('song-info-dialog');
		const songInfoCard = songInfoDialog ? songInfoDialog.querySelector('.song-info-card') : null;
		const songInfoClose = document.getElementById('song-info-close');
		const songInfoTitle = document.getElementById('song-info-title');
		const songInfoContent = document.getElementById('song-info-content');
		const bookmarkTitle = document.getElementById('bookmark-title');
		const historyTitle = document.getElementById('history-title');

		const defaultState = {
			version: STATE_VERSION,
			settings: {
				fontSize: 23,
				fontSizeMode: 'auto',
				fontWeight: 'bold',
				toolbarPosition: 'top',
				splitMode: false,
				congregation: CONGREGATION_OTHER,
			},
			history: [],
			bookmarks: [],
			searchHistory: [],
			lastViewed: '',
			languageMode: 'big5',
			layoutMode: 'single',
			filters: {
				collection: 'hymn_a',
				groupKey: '',
			},
		};

		const textSwapper = [
			['你', '祢'],
			['他', '祂'],
			['胆', '膽'],
			['群', '羣'],
			['举', '擧'],
			['并', '並'],
			['尝', '嘗'],
			['床', '牀'],
			['挂', '掛'],
			['汇', '滙'],
			['踪', '蹤'],
		];

		const GROUP_DEFINITIONS = {
			hymn_a: [
				{ key: 'category_default', label: '─ 詩歌類別 ─' },
				{ key: 'all', label: '全部' },
				{ key: 'a_1_21', label: '頌讚 - 父神', range: [1, 21] },
				{ key: 'a_22_96', label: '頌讚 - 耶穌基督', range: [22, 96] },
				{ key: 'a_97_105', label: '頌讚 - 聖靈', range: [97, 105] },
				{ key: 'a_106_154', label: '福音', range: [106, 154] },
				{ key: 'a_155_193', label: '道路 - 奉獻', range: [155, 193] },
				{ key: 'a_194_218', label: '道路 - 信靠', range: [194, 218] },
				{ key: 'a_219_242', label: '道路 - 引導', range: [219, 242] },
				{ key: 'a_243_261', label: '道路 - 順服', range: [243, 261] },
				{ key: 'a_262_273', label: '道路 - 受苦', range: [262, 273] },
				{ key: 'a_274_308', label: '道路 - 安慰', range: [274, 308] },
				{ key: 'a_309_326', label: '靈交 - 追求聖潔', range: [309, 326] },
				{ key: 'a_327_390', label: '靈交 - 與神合一', range: [327, 390] },
				{ key: 'a_391_412', label: '靈交 - 禱告交通', range: [391, 412] },
				{ key: 'a_413_429', label: '教會 - 教會生活', range: [413, 429] },
				{ key: 'a_430_447', label: '教會 - 爭戰', range: [430, 447] },
				{ key: 'a_448_471', label: '教會 - 盼望', range: [448, 471] },
				{ key: 'a_472_500', label: '教會 - 佈道', range: [472, 500] },
			],
			hymn_b: [
				{ key: 'category_default', label: '─ 詩歌類別 ─' },
				{ key: 'all', label: '全部' },
				{ key: 'b_1_33', label: '敬拜真神', range: [1, 33] },
				{ key: 'b_34_44', label: '頌讚父神', range: [34, 44] },
				{ key: 'b_45_110', label: '頌讚基督', range: [45, 110] },
				{ key: 'b_111_128', label: '基督降生', range: [111, 128] },
				{ key: 'b_129_152', label: '基督受苦', range: [129, 152] },
				{ key: 'b_153_159', label: '基督復活', range: [153, 159] },
				{ key: 'b_160_162', label: '基督再來', range: [160, 162] },
				{ key: 'b_163_196', label: '唱頌救恩', range: [163, 196] },
				{ key: 'b_197_250', label: '崇拜特輯', range: [197, 250] },
			],
			hymn_c: [
				{ key: 'category_default', label: '─ 詩歌類別 ─' },
				{ key: 'all', label: '全部' },
			],
			hymn_d: [
				{ key: 'category_default', label: '─ 詩歌類別 ─' },
				{ key: 'all', label: '全部' },
			],
		};
		const COLLECTION_FULL_PATHS = {
			hymn_a: toBasePath('data/hymn-a-full.json'),
			hymn_b: toBasePath('data/hymn-b-full.json'),
			hymn_c: toBasePath('data/hymn-c-full.json'),
			hymn_d: toBasePath('data/hymn-d-full.json'),
		};
		const HYMN_METADATA_PATH = toBasePath('data/hymn-a-metadata.json');

		let indexItems = [];
		let currentResults = [];
		let state = JSON.parse(JSON.stringify(defaultState));
		let currentLyricId = '';
		let lyricNavSource = 'search';
		let lyricNavSnapshotSource = '';
		let lyricNavSnapshotIds = [];
		let lyricSwipeAnimating = false;
		const lyricSwipeState = {
			pointerId: null,
			startX: 0,
			startY: 0,
			offsetX: 0,
			horizontal: false,
		};
		const lyricCacheRaw = new Map();
		const hymnMetadataById = new Map();
		let hymnMetadataLoadPromise = null;
		const lyricCollectionLoadPromises = new Map();
		let activeAudio = null;
		let activeAudioPath = '';
		let activeAudioObjectUrl = '';
		const OVERLAY_FADE_MS = 220;
		const SETTINGS_LAYOUT_SYNC_MS = 320;
		const HISTORY_AUTO_ADD_DELAY_MS = 5000;
		let bookmarkOverlayCloseTimer = null;
		let lyricOverlayCloseTimer = null;
		let historyAutoAddTimer = null;
		let historyAutoAddSongId = '';
		let settingsLayoutSyncRafId = 0;
		let settingsLayoutSyncUntil = 0;
		const AUDIO_CACHE_NAME = 'hymn-audio-v1';
		const AUDIO_CACHE_META_KEY = 'hymn_audio_cache_meta_v1';
		const AUDIO_CACHE_MAX_BYTES = 50 * 1024 * 1024;
		const AUDIO_CACHE_MAX_ENTRIES = 60;
		const AUDIO_ICON_PLAY = '<svg class="audio-btn-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path d="M8 5v14l11-7z"></path></svg>';
		const AUDIO_ICON_PAUSE = '<svg class="audio-btn-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path d="M7 5h4v14H7zM13 5h4v14h-4z"></path></svg>';
		const AUDIO_ICON_STOP = '<svg class="audio-btn-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path d="M7 7h10v10H7z"></path></svg>';

		function formatAudioTime(seconds) {
			if (!Number.isFinite(seconds) || seconds < 0) return '0:00';
			const mins = Math.floor(seconds / 60);
			const secs = Math.floor(seconds % 60)
				.toString()
				.padStart(2, '0');
			return `${mins}:${secs}`;
		}

		function getAudioTimeParts(seconds) {
			if (!Number.isFinite(seconds) || seconds < 0) {
				return { mins: '0', secs: '00' };
			}
			return {
				mins: String(Math.floor(seconds / 60)),
				secs: String(Math.floor(seconds % 60)).padStart(2, '0'),
			};
		}

		function normalizeAudioPath(pathValue = '') {
			const raw = String(pathValue || '').trim();
			if (!raw) return '';

			if (/^(blob:|https?:|data:)/i.test(raw)) {
				return raw;
			}

			const normalizedInput = `/${raw.replace(/^\/+/, '')}`;
			const baseRoot = `/${String(APP_BASE_URL || '/')
				.replace(/^\/+/, '')
				.replace(/\/+$/, '')}`;

			if (baseRoot !== '/' && (normalizedInput === baseRoot || normalizedInput.startsWith(`${baseRoot}/`))) {
				return normalizedInput;
			}

			return toBasePath(raw);
		}

		function updateAudioControlsUI(pathValue = '') {
			const playBtn = lyricViewer.querySelector('#audio-play');
			const timeLabel = lyricViewer.querySelector('#audio-time');
			const timeCurrent = lyricViewer.querySelector('#audio-time-current');
			const timeDuration = lyricViewer.querySelector('#audio-time-duration');
			const timeCurrentMin = lyricViewer.querySelector('#audio-time-current-min');
			const timeCurrentSec = lyricViewer.querySelector('#audio-time-current-sec');
			const timeDurationMin = lyricViewer.querySelector('#audio-time-duration-min');
			const timeDurationSec = lyricViewer.querySelector('#audio-time-duration-sec');
			if (!playBtn || !timeLabel) return;

			const normalized = normalizeAudioPath(pathValue);
			const isActive = Boolean(activeAudio && normalized && activeAudioPath === normalized);

			if (!isActive) {
				playBtn.innerHTML = AUDIO_ICON_PLAY;
				playBtn.setAttribute('aria-label', '播放 MP3');
				playBtn.setAttribute('title', '播放 MP3');
				if (timeCurrentMin && timeCurrentSec && timeDurationMin && timeDurationSec) {
					timeCurrentMin.textContent = '0';
					timeCurrentSec.textContent = '00';
					timeDurationMin.textContent = '0';
					timeDurationSec.textContent = '00';
				} else if (timeCurrent && timeDuration) {
					timeCurrent.textContent = '0:00';
					timeDuration.textContent = '0:00';
				} else {
					timeLabel.textContent = '0:00 / 0:00';
				}
				return;
			}

			if (activeAudio.paused) {
				playBtn.innerHTML = AUDIO_ICON_PLAY;
				playBtn.setAttribute('aria-label', activeAudio.currentTime > 0 ? '繼續播放 MP3' : '播放 MP3');
				playBtn.setAttribute('title', activeAudio.currentTime > 0 ? '繼續播放 MP3' : '播放 MP3');
			} else {
				playBtn.innerHTML = AUDIO_ICON_PAUSE;
				playBtn.setAttribute('aria-label', '暫停 MP3');
				playBtn.setAttribute('title', '暫停 MP3');
			}

			const currentParts = getAudioTimeParts(activeAudio.currentTime || 0);
			const durationParts = getAudioTimeParts(activeAudio.duration || 0);
			if (timeCurrentMin && timeCurrentSec && timeDurationMin && timeDurationSec) {
				timeCurrentMin.textContent = currentParts.mins;
				timeCurrentSec.textContent = currentParts.secs;
				timeDurationMin.textContent = durationParts.mins;
				timeDurationSec.textContent = durationParts.secs;
			} else if (timeCurrent && timeDuration) {
				const current = `${currentParts.mins}:${currentParts.secs}`;
				const duration = `${durationParts.mins}:${durationParts.secs}`;
				timeCurrent.textContent = current;
				timeDuration.textContent = duration;
			} else {
				const current = `${currentParts.mins}:${currentParts.secs}`;
				const duration = `${durationParts.mins}:${durationParts.secs}`;
				timeLabel.textContent = `${current} / ${duration}`;
			}
		}

		function bindActiveAudioEvents(pathValue) {
			if (!activeAudio) return;
			const syncUi = () => updateAudioControlsUI(pathValue);

			activeAudio.addEventListener('play', syncUi);
			activeAudio.addEventListener('pause', syncUi);
			activeAudio.addEventListener('timeupdate', syncUi);
			activeAudio.addEventListener('loadedmetadata', syncUi);
			activeAudio.addEventListener('ended', syncUi);
		}

		function parseCookie() {
			const out = {};
			document.cookie.split(';').forEach((entry) => {
				const trimmed = entry.trim();
				if (!trimmed) return;
				const idx = trimmed.indexOf('=');
				if (idx < 0) return;
				const key = decodeURIComponent(trimmed.slice(0, idx));
				const value = decodeURIComponent(trimmed.slice(idx + 1));
				out[key] = value;
			});
			return out;
		}

		function clearCookie(name) {
			document.cookie = `${encodeURIComponent(name)}=; expires=Thu, 01 Jan 1970 00:00:00 GMT; path=/; SameSite=Lax`;
		}

		function clearLegacyShelfCookies() {
			for (let i = 1; i <= LEGACY_SHELF_MAX; i += 1) {
				clearCookie(`bookmark_header${i}`);
				clearCookie(`bookmark_id${i}`);
				clearCookie(`history_header${i}`);
				clearCookie(`history_id${i}`);
			}
		}

		function extractLegacySongId(raw) {
			if (!raw) return '';
			const matched = String(raw).match(/hymn_[abc]_\d+[a-z]?/i);
			return matched ? matched[0].toLowerCase() : '';
		}

		function migrateLegacyState() {
			const migrated = JSON.parse(JSON.stringify(defaultState));
			const cookies = parseCookie();

			for (let i = 1; i <= LEGACY_SHELF_MAX; i += 1) {
				const header = localStorage.getItem(`bookmark_header${i}`) || cookies[`bookmark_header${i}`];
				const idNumber = localStorage.getItem(`bookmark_id${i}`) || cookies[`bookmark_id${i}`];
				const id = extractLegacySongId(`${header || ''}_${idNumber || ''}`);
				if (!id) continue;
				migrated.bookmarks.push({ id, title: '', number: '', collection: '', at: Date.now() - i * 1000 });
			}

			for (let i = 1; i <= LEGACY_SHELF_MAX; i += 1) {
				const header = localStorage.getItem(`history_header${i}`) || cookies[`history_header${i}`];
				const idNumber = localStorage.getItem(`history_id${i}`) || cookies[`history_id${i}`];
				const id = extractLegacySongId(`${header || ''}_${idNumber || ''}`);
				if (!id) continue;
				migrated.history.push({ id, title: '', number: '', collection: '', at: Date.now() - i * 1000 });
			}

			migrated.bookmarks = migrated.bookmarks.slice(0, LEGACY_SHELF_MAX);
			migrated.history = migrated.history.slice(0, LEGACY_SHELF_MAX);
			return migrated;
		}

		function sanitizeSearchHistory(rawHistory) {
			if (!Array.isArray(rawHistory)) return [];

			const out = [];
			const seen = new Set();
			for (const entry of rawHistory) {
				const value = String(entry ?? '').trim();
				if (!value) continue;
				const key = value.toLowerCase();
				if (seen.has(key)) continue;
				seen.add(key);
				out.push(value);
				if (out.length >= SEARCH_HISTORY_MAX) break;
			}
			return out;
		}

		function loadState() {
			try {
				const raw = localStorage.getItem(STORAGE_KEY);
				if (!raw) {
					state = migrateLegacyState();
					normalizeFontSizePreference();
					clearLegacyShelfCookies();
					return;
				}

				const parsed = JSON.parse(raw);
				if (parsed.version === STATE_VERSION) {
					state = {
						...defaultState,
						...parsed,
						settings: {
							...defaultState.settings,
							...(parsed.settings || {}),
						},
						history: Array.isArray(parsed.history) ? parsed.history : [],
						bookmarks: Array.isArray(parsed.bookmarks) ? parsed.bookmarks : [],
						searchHistory: sanitizeSearchHistory(parsed.searchHistory),
						filters: {
							...defaultState.filters,
							...(parsed.filters || {}),
						},
					};
					normalizeFontSizePreference(parsed.settings || {});
					return;
				}

				state = {
					...migrateLegacyState(),
					...parsed,
					version: STATE_VERSION,
				};
				state.settings = {
					...defaultState.settings,
					...(state.settings || {}),
				};
				state.searchHistory = sanitizeSearchHistory(state.searchHistory);
				normalizeFontSizePreference(parsed.settings || {});
			} catch {
				state = migrateLegacyState();
				normalizeFontSizePreference();
			}
		}

		function clampFontSize(rawValue) {
			const parsed = Number.parseInt(rawValue, 10);
			if (!Number.isFinite(parsed)) {
				return getResponsiveDefaultFontSize();
			}
			return Math.min(FONT_SIZE_MAX, Math.max(FONT_SIZE_MIN, parsed));
		}

		function normalizeFontSizePreference(parsedSettings = null) {
			const settings = state.settings || {};
			const hasMode = settings.fontSizeMode === 'auto' || settings.fontSizeMode === 'manual';
			if (!hasMode) {
				const sourceSettings =
					parsedSettings && typeof parsedSettings === 'object'
						? parsedSettings
						: settings && typeof settings === 'object'
							? settings
							: {};
				const hasStoredFontSize = Object.prototype.hasOwnProperty.call(sourceSettings, 'fontSize');
				const looksLikeLegacyDefault = clampFontSize(settings.fontSize) === 23;
				settings.fontSizeMode = hasStoredFontSize && !looksLikeLegacyDefault ? 'manual' : 'auto';
			}

			if (settings.fontSizeMode === 'auto') {
				settings.fontSize = getResponsiveDefaultFontSize();
			} else {
				settings.fontSizeMode = 'manual';
				settings.fontSize = clampFontSize(settings.fontSize);
			}

			state.settings = settings;
		}

		function hideSearchHistoryOverlay() {
			searchHistoryOverlay.classList.remove('is-open');
			searchHistoryOverlay.setAttribute('aria-hidden', 'true');
		}

		function renderSearchHistoryOverlay() {
			const historyEntries = sanitizeSearchHistory(state.searchHistory);
			state.searchHistory = historyEntries;
			if (!historyEntries.length) {
				hideSearchHistoryOverlay();
				return;
			}

			searchHistoryList.innerHTML = historyEntries
				.map(
					(entry) => `
						<div class="search-history-row" data-query="${escapeHtml(entry)}">
							<button type="button" class="search-history-item" data-query="${escapeHtml(entry)}">
								${escapeHtml(entry)}
							</button>
							<button
								type="button"
								class="search-history-remove"
								data-action="remove-search-history"
								data-query="${escapeHtml(entry)}"
								aria-label="${escapeHtml(convertByLang('移除搜尋記錄', state.languageMode))}: ${escapeHtml(entry)}"
							>
								x
							</button>
						</div>
					`,
				)
				.join('');

			searchHistoryOverlay.classList.add('is-open');
			searchHistoryOverlay.setAttribute('aria-hidden', 'false');
		}

		function recordSearchHistory(rawQuery) {
			const query = String(rawQuery ?? '').trim();
			if (!query) return;

			const key = query.toLowerCase();
			const deduped = (state.searchHistory || []).filter((entry) => String(entry ?? '').trim().toLowerCase() !== key);
			state.searchHistory = [query, ...deduped].slice(0, SEARCH_HISTORY_MAX);
			saveState();
		}

		function executeSearchWithCurrentInput() {
			const query = input.value.trim();
			if (query) {
				recordSearchHistory(query);
			}
			hideSearchHistoryOverlay();
			doSearch(true, true, true);
		}

		function saveState() {
			state.version = STATE_VERSION;
			localStorage.setItem(STORAGE_KEY, JSON.stringify(state));
		}

		function escapeHtml(text) {
			return text
				.replaceAll('&', '&amp;')
				.replaceAll('<', '&lt;')
				.replaceAll('>', '&gt;')
				.replaceAll('"', '&quot;')
				.replaceAll("'", '&#39;');
		}

		function normalize(inputText) {
			return inputText
				.normalize('NFKC')
				.toLowerCase()
				.replace(/[\u3000\s]+/g, ' ')
				.replace(/[\p{P}\p{S}]+/gu, ' ')
				.replace(/\s+/g, ' ')
				.trim();
		}

		function parseSongNumberToken(inputText) {
			const compact = String(inputText ?? '')
				.normalize('NFKC')
				.toLowerCase()
				.replace(/\s+/g, '');

			const matched = compact.match(/^0*(\d+)([a-z])?$/i);
			if (!matched) return null;

			const base = Number.parseInt(matched[1], 10);
			if (Number.isNaN(base)) return null;

			return {
				base,
				suffix: (matched[2] || '').toLowerCase(),
			};
		}

		function buildSearchQueryText(rawInput) {
			const raw = String(rawInput ?? '');
			if (state.languageMode === 'gb') {
				// Keep the UI input unchanged; convert only the internal query for matching traditional-stored lyrics.
				// NOTE: This must stay independent from convertByLang('big5') display behavior.
				let traditionalQuery = raw;
				if (typeof window.convertText === 'function') {
					try {
						traditionalQuery = window.convertText(traditionalQuery, 'big5');
					} catch {
						// Ignore and keep fallback conversion below.
					}
				}
				return traditionalQuery;
			}
			return raw;
		}

		function foldVariantsForSearch(inputText) {
			let out = String(inputText ?? '');
			for (const [variantA, variantB] of textSwapper) {
				out = out.split(variantA).join(variantB);
			}
			// Keep legacy 耀/燿 normalization for search-only matching.
			out = out.split('燿').join('耀');
			return out;
		}

		function convertByLang(inputText, mode) {
			let out = String(inputText ?? '');
			// Source data is already traditional; running legacy big5 conversion may introduce variant glyphs
			// like 耀 -> 燿. Only run full-table conversion when switching to simplified mode.
			if (mode === 'gb' && typeof window.convertText === 'function') {
				try {
					out = window.convertText(out, mode);
				} catch {
					// Ignore and use fallback mapping below.
				}
			}
			return out;
		}

		function convertLyricsHtmlByLang(lyricsHtml, mode, collection) {
			void collection;
			return convertByLang(lyricsHtml, mode);
		}

		function applyLanguageToStaticUI() {
			const convert = (text) => convertByLang(text, state.languageMode);

			input.setAttribute('placeholder', convert('歌曲編號 / 歌詞內容'));
			searchBtn.setAttribute('aria-label', convert('搜尋'));
			searchBtn.setAttribute('title', convert('搜尋'));
			toggleSettingsBtn.setAttribute('aria-label', convert('設定'));
			toggleSettingsBtn.setAttribute('title', convert('設定'));

			quickbarBookmark.setAttribute('aria-label', convert('書籤'));
			quickbarBookmark.setAttribute('title', convert('書籤'));
			const quickbarBookmarkText = quickbarBookmark.querySelector('span');
			if (quickbarBookmarkText) quickbarBookmarkText.textContent = convert('書籤');

			quickbarSearch.setAttribute('aria-label', convert('搜索'));
			quickbarSearch.setAttribute('title', convert('搜索'));
			const quickbarSearchText = quickbarSearch.querySelector('span');
			if (quickbarSearchText) quickbarSearchText.textContent = convert('搜索');

			if (fontSizeLabel) fontSizeLabel.textContent = convert('字體大小');
			if (languageLabel) languageLabel.textContent = convert('語言');
			if (congregationLabel) congregationLabel.textContent = convert('堂會');
			if (congregationOtherLabel) congregationOtherLabel.textContent = convert('其他堂會');
			if (congregationKpypLabel) congregationKpypLabel.textContent = convert('葵平/涌平');
			if (congregationShtLabel) congregationShtLabel.textContent = convert('沙平');
			const big5Option = settingLanguage.querySelector('option[value="big5"]');
			const gbOption = settingLanguage.querySelector('option[value="gb"]');
			if (big5Option) big5Option.textContent = convert('繁體');
			if (gbOption) gbOption.textContent = convert('簡體');

			settingsCloseBtn.textContent = convert('關閉');
			settingsCloseBtn.setAttribute('aria-label', convert('關閉設定'));

			if (bookmarkTitle) bookmarkTitle.textContent = convert('我的書籤');
			if (historyTitle) historyTitle.textContent = convert('瀏覽記錄');
		}

		function normalizeCongregation(value) {
			if (value === CONGREGATION_KP_YP) return CONGREGATION_KP_YP;
			if (value === CONGREGATION_SHT) return CONGREGATION_SHT;
			return CONGREGATION_OTHER;
		}

		function applyStateToUI() {
			state.layoutMode = 'single';
			state.settings.splitMode = false;
			state.settings.fontWeight = 'bold';
			state.settings.toolbarPosition = 'top';
			normalizeFontSizePreference();
			state.settings.congregation = normalizeCongregation(state.settings.congregation);

			document.documentElement.style.setProperty('--lyric-font-size', `${state.settings.fontSize}px`);
			document.documentElement.style.setProperty('--lyric-font-weight', state.settings.fontWeight);

			document.body.classList.remove('theme-night');
			document.body.classList.add('theme-warm');

			hymnApp.classList.toggle('single-mode', state.layoutMode === 'single');
			hymnApp.dataset.toolbar = state.settings.toolbarPosition;

			settingFontSize.value = String(state.settings.fontSize);
			settingLanguage.value = state.languageMode;
			for (const option of congregationRadioOptions) {
				option.checked = option.value === state.settings.congregation;
			}
			applyLanguageToStaticUI();
		}

		function upsertEntry(list, payload) {
			const idx = list.findIndex((entry) => entry.id === payload.id);
			const entry = {
				id: payload.id,
				title: payload.title,
				number: payload.number,
				collection: payload.collection,
				at: Date.now(),
			};
			if (idx >= 0) {
				list.splice(idx, 1);
			}
			list.unshift(entry);
			return list.slice(0, 20);
		}

		function isBookmarked(id) {
			return state.bookmarks.some((entry) => entry.id === id);
		}

		function findItemById(id) {
			return indexItems.find((entry) => entry.id === id);
		}

		function backfillShelfEntriesFromIndex(entries) {
			if (!Array.isArray(entries)) return [];
			return entries.map((entry) => {
				const item = findItemById(entry?.id);
				if (!item) return entry;
				return {
					...entry,
					title: item.title || entry.title || '',
					number: item.number || entry.number || '',
					collection: item.collection || entry.collection || '',
				};
			});
		}

		function syncShelfEntriesFromIndex() {
			state.bookmarks = backfillShelfEntriesFromIndex(state.bookmarks);
			state.history = backfillShelfEntriesFromIndex(state.history);
		}

		function getCollectionLabel(collection) {
			if (collection === 'hymn_a') return '平安詩集';
			if (collection === 'hymn_b') return '敬拜頌歌';
			if (collection === 'hymn_c') return '詩歌集';
			if (collection === 'hymn_d') return '沙平匯曲';
			return collection;
		}

		function getCollectionShortLabel(collection) {
			if (collection === 'hymn_a') return '平';
			if (collection === 'hymn_b') return '敬';
			if (collection === 'hymn_c') return '詩';
			if (collection === 'hymn_d') return '沙';
			return getCollectionLabel(collection);
		}

		function getActiveCongregation() {
			return normalizeCongregation(state.settings?.congregation);
		}

		function getCongregationFromHash() {
			const rawHash = String(window.location.hash || '').replace(/^#/, '').trim().toLowerCase();
			if (
				rawHash === CONGREGATION_HASH_KP_YP ||
				rawHash === CONGREGATION_HASH_KP ||
				rawHash === CONGREGATION_HASH_SKC
			) {
				return CONGREGATION_KP_YP;
			}
			if (rawHash === CONGREGATION_HASH_SHT) {
				return CONGREGATION_SHT;
			}
			return '';
		}

		function syncHashByCongregation(congregation) {
			let nextHash = '';
			if (congregation === CONGREGATION_KP_YP) {
				nextHash = `#${CONGREGATION_HASH_KP_YP}`;
			} else if (congregation === CONGREGATION_SHT) {
				nextHash = `#${CONGREGATION_HASH_SHT}`;
			}
			if (window.location.hash === nextHash) return;

			const nextUrl = `${window.location.pathname}${window.location.search}${nextHash}`;
			window.history.replaceState(null, '', nextUrl);
		}

		function getAllowedCollections() {
			const congregation = getActiveCongregation();
			if (congregation === CONGREGATION_KP_YP) {
				return ['hymn_a', 'hymn_b', 'hymn_c'];
			}
			if (congregation === CONGREGATION_SHT) {
				return ['hymn_a', 'hymn_b', 'hymn_d'];
			}
			return ['hymn_a', 'hymn_b'];
		}

		function isCollectionAllowed(collection) {
			return getAllowedCollections().includes(collection);
		}

		function sanitizeFiltersForCongregation() {
			const allowedCollections = getAllowedCollections();
			let targetCollection = state.filters?.collection;
			if (!targetCollection || !GROUP_DEFINITIONS[targetCollection] || !allowedCollections.includes(targetCollection)) {
				targetCollection = allowedCollections.includes('hymn_a') ? 'hymn_a' : allowedCollections[0] || 'hymn_a';
			}

			state.filters.collection = targetCollection;
			const groupKey = state.filters?.groupKey;
			const hasGroup = (GROUP_DEFINITIONS[targetCollection] || []).some((group) => group.key === groupKey);
			if (!hasGroup) {
				state.filters.groupKey = getDefaultGroupKey(targetCollection);
			}
		}

		function getActiveCollection() {
			const candidate = state.filters?.collection;
			const allowedCollections = getAllowedCollections();
			if (candidate && GROUP_DEFINITIONS[candidate] && allowedCollections.includes(candidate)) return candidate;
			if (allowedCollections.includes('hymn_a')) return 'hymn_a';
			return allowedCollections[0] || 'hymn_a';
		}

		function getActiveGroups() {
			return GROUP_DEFINITIONS[getActiveCollection()] || [];
		}

		function getDefaultGroupKey(collection) {
			const groups = GROUP_DEFINITIONS[collection] || [];
			return groups.find((group) => group.key === 'category_default')?.key || groups.find((group) => group.key === 'all')?.key || groups[0]?.key || '';
		}

		function getActiveGroup() {
			const key = state.filters?.groupKey;
			if (!key) return null;
			return getActiveGroups().find((group) => group.key === key) || null;
		}

		function itemWithinGroup(item, group) {
			if (!group || !group.range) return true;
			const num = Number.parseInt(item.number, 10);
			if (Number.isNaN(num)) return false;
			return num >= group.range[0] && num <= group.range[1];
		}

		function getItemsInActiveGroup() {
			const activeCollection = getActiveCollection();
			const activeGroup = getActiveGroup();
			if (!activeGroup) return [];
			return indexItems.filter((item) => item.collection === activeCollection && itemWithinGroup(item, activeGroup));
		}

		function findGroupKeyForItem(item) {
			const groups = GROUP_DEFINITIONS[item?.collection] || [];
			if (!groups.length) return '';

			const number = Number.parseInt(item?.number || '', 10);
			if (!Number.isNaN(number)) {
				const matched = groups.find((group) => group.range && number >= group.range[0] && number <= group.range[1]);
				if (matched) return matched.key;
			}

			return groups.find((group) => group.key === 'all')?.key || groups[0].key || '';
		}

		function renderGroupList() {
			const activeGroupKey = state.filters?.groupKey;
			groupList.innerHTML = getActiveGroups()
				.map(
					(group) => `
						<option value="${group.key}" ${group.key === activeGroupKey ? 'selected' : ''}>
							${escapeHtml(convertByLang(group.label, state.languageMode))}
						</option>
					`,
				)
				.join('');
		}

		function renderQuickbar() {
			const activeCollection = getActiveCollection();
			const useShortLabel = window.innerWidth < 820;
			quickbarCollections.innerHTML = getAllowedCollections()
				.map(
					(collection) => `
						<button
							type="button"
							class="quickbar-chip ${collection === activeCollection ? 'active' : ''}"
							data-collection="${collection}"
						>${escapeHtml(convertByLang(useShortLabel ? getCollectionShortLabel(collection) : getCollectionLabel(collection), state.languageMode))}</button>
					`,
				)
				.join('');
			syncQuickbarCollectionVisibility();
		}

		function syncQuickbarCollectionVisibility() {
			const quickbarWidth = floatingQuickbar?.clientWidth || 0;
			floatingQuickbar.classList.remove('actions-icon-only');
			floatingQuickbar.classList.remove('collections-hidden');

			const bookmarkWidthWithText = quickbarBookmark?.offsetWidth || 0;
			const searchWidthWithText = quickbarSearch?.offsetWidth || 0;
			const reservedWidthWithText =
				bookmarkWidthWithText + searchWidthWithText + QUICKBAR_EDGE_PADDING + QUICKBAR_COLLECTIONS_MIN_WIDTH;

			const needsIconOnlyActions = quickbarWidth < reservedWidthWithText;
			floatingQuickbar.classList.toggle('actions-icon-only', needsIconOnlyActions);

			const bookmarkWidthCurrent = quickbarBookmark?.offsetWidth || 0;
			const searchWidthCurrent = quickbarSearch?.offsetWidth || 0;
			const reservedWidthCurrent =
				bookmarkWidthCurrent + searchWidthCurrent + QUICKBAR_EDGE_PADDING + QUICKBAR_COLLECTIONS_MIN_WIDTH;
			const hasEnoughSpaceForCollections = quickbarWidth >= reservedWidthCurrent;
			floatingQuickbar.classList.toggle('collections-hidden', !hasEnoughSpaceForCollections);
		}

		function closeSettingsPanel() {
			startSettingsLayoutSync();
			settingsPanel.classList.remove('is-open');
			updateResultViewportLayout();
		}

		function updateSettingsPanelOpenHeight() {
			const measured = Math.ceil(settingsPanel.scrollHeight + 24);
			settingsPanel.style.setProperty('--settings-panel-open-height', `${measured}px`);
		}

		function openSettingsPanel() {
			startSettingsLayoutSync();
			updateSettingsPanelOpenHeight();
			settingsPanel.classList.add('is-open');
			requestAnimationFrame(() => {
				updateSettingsPanelOpenHeight();
				updateResultViewportLayout();
			});
		}

		function startSettingsLayoutSync(durationMs = SETTINGS_LAYOUT_SYNC_MS) {
			const now = performance.now();
			settingsLayoutSyncUntil = Math.max(settingsLayoutSyncUntil, now + durationMs);

			if (settingsLayoutSyncRafId) {
				return;
			}

			const tick = (timestamp) => {
				updateResultViewportLayout();
				if (timestamp < settingsLayoutSyncUntil) {
					settingsLayoutSyncRafId = requestAnimationFrame(tick);
					return;
				}
				settingsLayoutSyncRafId = 0;
			};

			settingsLayoutSyncRafId = requestAnimationFrame(tick);
		}

		function clearHistoryAutoAddTimer() {
			if (historyAutoAddTimer) {
				clearTimeout(historyAutoAddTimer);
				historyAutoAddTimer = null;
			}
			historyAutoAddSongId = '';
		}

		function scheduleHistoryAutoAdd(payload) {
			clearHistoryAutoAddTimer();
			if (!payload?.id) return;

			historyAutoAddSongId = payload.id;
			historyAutoAddTimer = setTimeout(() => {
				historyAutoAddTimer = null;
				const targetId = historyAutoAddSongId;
				historyAutoAddSongId = '';

				if (!targetId || currentLyricId !== targetId) return;
				if (!lyricOverlay.classList.contains('overlay-visible')) return;

				state.history = upsertEntry(state.history, payload);
				saveState();
				renderShelves();
			}, HISTORY_AUTO_ADD_DELAY_MS);
		}

		function closeAllOpenPanels() {
			closeLyricOverlay();
			closeBookmarkOverlay();
			closeSettingsPanel();
		}

		function updateResultViewportLayout() {
			let topSpace = (topControlsOverlay?.offsetHeight || 0) + 2;
			if (window.innerWidth >= 820) {
				topSpace = Math.max(0, topSpace - 10);
			}
			hymnApp.style.paddingTop = `${topSpace}px`;

			let bottomSpace = 10;
			if (floatingQuickbar) {
				const quickRect = floatingQuickbar.getBoundingClientRect();
				bottomSpace = Math.max(16, Math.ceil(window.innerHeight - quickRect.top) + 10);
			}

			// Keep mobile list taller while preserving enough room for the fixed quickbar.
			if (window.innerWidth < 820) {
				bottomSpace = Math.max(12, bottomSpace - 8);
			}

			// Tablet/desktop still reserve some breathing room above the quickbar.
			if (window.innerWidth >= 820) {
				bottomSpace = Math.max(18, bottomSpace - 4);
			}

			const listRect = resultList.getBoundingClientRect();
			const available = Math.floor(window.innerHeight - bottomSpace - listRect.top);
			resultList.style.height = `${Math.max(200, available)}px`;
		}

		function updateOverlayBodyState() {
			const anyOpen =
				bookmarkOverlay.classList.contains('overlay-visible') ||
				lyricOverlay.classList.contains('overlay-visible');
			const bookmarkOpen = bookmarkOverlay.classList.contains('overlay-visible');
			const lyricOpen = lyricOverlay.classList.contains('overlay-visible');
			document.body.classList.toggle('overlay-open', anyOpen);
			document.body.classList.toggle('bookmark-overlay-open', bookmarkOpen);
			document.body.classList.toggle('lyric-overlay-open', lyricOpen);
		}

		function clearOverlayCloseTimer(overlayEl) {
			if (overlayEl === bookmarkOverlay && bookmarkOverlayCloseTimer) {
				clearTimeout(bookmarkOverlayCloseTimer);
				bookmarkOverlayCloseTimer = null;
			}
			if (overlayEl === lyricOverlay && lyricOverlayCloseTimer) {
				clearTimeout(lyricOverlayCloseTimer);
				lyricOverlayCloseTimer = null;
			}
		}

		function showOverlay(overlayEl) {
			clearOverlayCloseTimer(overlayEl);
			overlayEl.classList.remove('hidden-panel');
			requestAnimationFrame(() => {
				overlayEl.classList.add('overlay-visible');
				updateOverlayBodyState();
			});
			overlayEl.setAttribute('aria-hidden', 'false');
		}

		function hideOverlay(overlayEl, options = {}) {
			const immediate = options.immediate === true;
			clearOverlayCloseTimer(overlayEl);
			overlayEl.classList.remove('overlay-visible');
			overlayEl.setAttribute('aria-hidden', 'true');

			if (immediate) {
				overlayEl.classList.add('hidden-panel');
				updateOverlayBodyState();
				return;
			}

			const hideLater = () => {
				overlayEl.classList.add('hidden-panel');
				if (overlayEl === bookmarkOverlay) {
					bookmarkOverlayCloseTimer = null;
				}
				if (overlayEl === lyricOverlay) {
					lyricOverlayCloseTimer = null;
				}
			};

			if (overlayEl === bookmarkOverlay) {
				bookmarkOverlayCloseTimer = setTimeout(hideLater, OVERLAY_FADE_MS);
			}
			if (overlayEl === lyricOverlay) {
				lyricOverlayCloseTimer = setTimeout(hideLater, OVERLAY_FADE_MS);
			}
			updateOverlayBodyState();
		}

		function openBookmarkOverlay() {
			closeLyricOverlay({ immediate: true });
			showOverlay(bookmarkOverlay);
		}

		function closeBookmarkOverlay(options = {}) {
			hideOverlay(bookmarkOverlay, options);
		}

		function resetLyricOverlayScroll() {
			if (lyricOverlayCard) {
				lyricOverlayCard.scrollTop = 0;
			}
			if (lyricViewer) {
				lyricViewer.scrollTop = 0;
			}
		}

		function openLyricOverlay() {
			closeBookmarkOverlay({ immediate: true });
			showOverlay(lyricOverlay);
			resetLyricOverlayScroll();
			requestAnimationFrame(updateLyricSideNavBounds);
		}

		function closeLyricOverlay(options = {}) {
			clearHistoryAutoAddTimer();
			closeSongInfoDialog();
			hideOverlay(lyricOverlay, options);
			lyricSwipeAnimating = false;
			resetLyricSwipePosition();
		}

		function setActiveCollection(collection) {
			if (!GROUP_DEFINITIONS[collection] || !isCollectionAllowed(collection)) return;
			state.filters.collection = collection;
			state.filters.groupKey = getDefaultGroupKey(collection);
			input.value = '';
			renderQuickbar();
			renderGroupList();
			renderResults([]);
			doSearch();
			saveState();
		}

		function setActiveGroup(groupKey) {
			const found = getActiveGroups().find((group) => group.key === groupKey);
			if (!found) return;
			state.filters.groupKey = groupKey;
			input.value = '';
			renderGroupList();
			doSearch();
			saveState();
		}

		function syncFiltersForBrowsingItem(item, options = {}) {
			if (!item || !GROUP_DEFINITIONS[item.collection] || !isCollectionAllowed(item.collection)) return;

			const targetCollection = item.collection;
			const targetGroupKey = options.useDefaultGroup
				? getDefaultGroupKey(targetCollection)
				: findGroupKeyForItem(item) || getDefaultGroupKey(targetCollection);
			const shouldUpdateCollection = state.filters.collection !== targetCollection;
			const shouldUpdateGroup = state.filters.groupKey !== targetGroupKey;

			if (!shouldUpdateCollection && !shouldUpdateGroup) {
				return;
			}

			state.filters.collection = targetCollection;
			state.filters.groupKey = targetGroupKey;
			renderQuickbar();
			renderGroupList();
			doSearch(false, false);
			saveState();
		}

		function renderShelfList(targetEl, entries, emptyText) {
			if (!entries.length) {
				targetEl.innerHTML = `<div class="empty-state compact">${convertByLang(emptyText, state.languageMode)}</div>`;
				return;
			}

			targetEl.innerHTML = entries
				.map((entry) => {
					const item = findItemById(entry.id);
					const title = convertByLang(item?.title || entry.title || entry.id, state.languageMode);
					const number = item?.number || entry.number || '--';
					return `
						<div class="shelf-item" data-id="${entry.id}">
							<button type="button" class="shelf-open" data-action="open" data-id="${entry.id}">
								<span class="shelf-number-left">${escapeHtml(number)}</span>
								<span class="shelf-title-center">${escapeHtml(title)}</span>
								<span class="shelf-number-pad" aria-hidden="true">${escapeHtml(number)}</span>
							</button>
							<button type="button" class="shelf-remove" data-action="remove" data-id="${entry.id}" aria-label="${escapeHtml(convertByLang('刪除', state.languageMode))}">
								<svg class="shelf-remove-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
									<path d="M4 7h16M9 7V5h6v2M7 7l1 12h8l1-12M10 11v6M14 11v6"></path>
								</svg>
							</button>
						</div>
					`;
				})
				.join('');
		}

		function renderShelves() {
			const filterEntries = (entries) =>
				(entries || []).filter((entry) => {
					const item = findItemById(entry?.id || '');
					const collection = item?.collection || entry?.collection || '';
					if (!collection) return true;
					return isCollectionAllowed(collection);
				});

			renderShelfList(bookmarkList, filterEntries(state.bookmarks), '尚無書籤');
			renderShelfList(historyList, filterEntries(state.history), '尚無瀏覽記錄');
		}

		function renderResults(results) {
			if (!results.length) {
				resultList.innerHTML = '<div class="empty-state">找不到符合的詩歌，請試試其他關鍵詞。</div>';
				return;
			}

			resultList.innerHTML = results
				.map(
					(item) => {
						const numberText = String(item.number || '').trim();
						const displayNumber = /^\d+$/.test(numberText)
							? numberText.padStart(3, '0')
							: numberText;
						const displayCollection = convertByLang(getCollectionShortLabel(item.collection), state.languageMode);
						const displayNumberWithCollectionHtml = `<span class="result-collection-prefix">${escapeHtml(displayCollection)}</span>${escapeHtml(displayNumber)}`;
						const displayTitle = convertByLang(item.title, state.languageMode);

						return `
						<button type="button" class="result-item" data-id="${item.id}">
							<span class="result-number-left">${displayNumberWithCollectionHtml}</span>
							<span class="result-title-center">${escapeHtml(displayTitle)}</span>
							<span class="result-number-pad" aria-hidden="true">${displayNumberWithCollectionHtml}</span>
						</button>
						`;
					},
				)
				.join('');
		}

		function setResultActive(id) {
			resultList.querySelectorAll('.result-item').forEach((el) => {
				if (el.getAttribute('data-id') === id) {
					el.classList.add('active');
				} else {
					el.classList.remove('active');
				}
			});
		}

		function getLyricNavItemsFromLiveSource(source = lyricNavSource) {
			if (source === 'bookmarks') {
				return state.bookmarks
					.map((entry) => findItemById(entry.id))
					.filter((item) => item && isCollectionAllowed(item.collection));
			}

			if (source === 'history') {
				return state.history
					.map((entry) => findItemById(entry.id))
					.filter((item) => item && isCollectionAllowed(item.collection));
			}

			return currentResults;
		}

		function getLyricNavItems(source = lyricNavSource) {
			if (source === lyricNavSnapshotSource && lyricNavSnapshotIds.length) {
				return lyricNavSnapshotIds
					.map((id) => findItemById(id))
					.filter(Boolean);
			}
			return getLyricNavItemsFromLiveSource(source);
		}

		function getLyricNavInfo(currentId, source = lyricNavSource) {
			const items = getLyricNavItems(source);
			const index = items.findIndex((entry) => entry.id === currentId);
			const hasCurrent = index >= 0;
			const prevItem = hasCurrent && index > 0 ? items[index - 1] : null;
			const nextItem = hasCurrent && index < items.length - 1 ? items[index + 1] : null;

			return {
				items,
				index,
				hasCurrent,
				prevItem,
				nextItem,
			};
		}

		async function ensureCollectionLyricsLoaded(collection) {
			if (!collection) return;
			if (lyricCollectionLoadPromises.has(collection)) {
				await lyricCollectionLoadPromises.get(collection);
				return;
			}

			const fullPath = COLLECTION_FULL_PATHS[collection];
			if (!fullPath) {
				throw new Error(`Unknown collection: ${collection}`);
			}

			const loadPromise = (async () => {
				const resp = await fetch(fullPath, { cache: 'force-cache' });
				if (!resp.ok) {
					throw new Error(`Cannot load ${fullPath}`);
				}
				const data = await resp.json();
				const items = data.items || [];
				for (const payload of items) {
					if (payload?.id) {
						lyricCacheRaw.set(payload.id, payload);
					}
				}
			})();

			lyricCollectionLoadPromises.set(collection, loadPromise);
			try {
				await loadPromise;
			} catch (error) {
				lyricCollectionLoadPromises.delete(collection);
				throw error;
			}
		}

		async function loadLyricPayloadByItem(item) {
			if (!item) return null;
			let payload = lyricCacheRaw.get(item.id);
			if (payload) return payload;

			await ensureCollectionLyricsLoaded(item.collection);
			payload = lyricCacheRaw.get(item.id);
			if (!payload) {
				throw new Error(`Cannot find lyric payload for ${item.id}`);
			}
			return payload;
		}

		function renderSwipeSide(payload, emptyText) {
			if (!payload) {
				return `<div class="empty-state compact lyric-side-empty">${emptyText}</div>`;
			}

			const convertedTitle = convertByLang(payload.title, state.languageMode);
			const convertedLyricsHtml = convertLyricsHtmlByLang(payload.lyricsHtml, state.languageMode, payload.collection);
			const reportSongNumber = `${convertByLang(getCollectionShortLabel(payload.collection), state.languageMode)}${String(payload.number || '').trim()}`;
			const reportSubject = '平安詩集 - 錯誤回報';
			const reportBody = `${reportSongNumber} - 錯誤詳情: (請填寫)`;
			const reportHref = `mailto:hkpec.hymn@gmail.com?subject=${encodeURIComponent(reportSubject)}&body=${encodeURIComponent(reportBody)}`;
			const bookmarked = isBookmarked(payload.id);
			const bookmarkLabel = bookmarked ? '取消書籤' : '加入書籤';
			const sideAudioControls = payload.audioPath
				? `
					<button type="button" class="search-btn audio-icon-btn" tabindex="-1" aria-hidden="true">${AUDIO_ICON_PLAY}</button>
					<button type="button" class="search-btn subtle audio-icon-btn" tabindex="-1" aria-hidden="true">${AUDIO_ICON_STOP}</button>
					<span class="audio-time" aria-hidden="true">0:00 / 0:00</span>
				`
				: '';
			return `
				<div class="lyric-side-inner" aria-hidden="true">
					<div class="lyric-header lyric-header-side">
						<div>
							<h3 class="lyric-song-title">${escapeHtml(payload.number)} ${escapeHtml(convertedTitle)}</h3>
						</div>
						<div class="viewer-actions viewer-actions-placeholder" aria-hidden="true">
							<div class="viewer-audio-actions">
								${sideAudioControls}
							</div>
							<button type="button" class="search-btn subtle viewer-bookmark-btn ${bookmarked ? 'is-bookmarked' : ''}" tabindex="-1" aria-hidden="true">
								<svg class="bookmark-btn-icon" viewBox="0 0 24 24" focusable="false">
									<path d="M6 3h12a1 1 0 0 1 1 1v17l-7-4-7 4V4a1 1 0 0 1 1-1z"></path>
								</svg>
								<span>${bookmarkLabel}</span>
							</button>
						</div>
					</div>
					<div class="lyric-body">${convertedLyricsHtml}</div>
					<div class="lyric-report-wrap lyric-report-wrap-placeholder" aria-hidden="true">
						<a class="search-btn subtle lyric-report-btn" href="${escapeHtml(reportHref)}" tabindex="-1">問題回報</a>
					</div>
				</div>
			`;
		}

		function isValidSourceUrl(url) {
			if (!url) return false;
			try {
				const parsed = new URL(normalizeSourceUrl(url));
				return parsed.protocol === 'http:' || parsed.protocol === 'https:';
			} catch {
				return false;
			}
		}

		function normalizeSourceUrl(url) {
			return String(url || '')
				.trim()
				.replace(/[。．，,；;：:！!？?]+$/u, '');
		}

		function getSourceSiteName(url, sourceLabel = '') {
			const normalizedLabel = String(sourceLabel || '').trim().toLowerCase().replace(/^www\./, '');
			if (normalizedLabel) {
				if (normalizedLabel.includes('wikipedia')) return 'wikipedia';
				return normalizedLabel.split('.')[0] || normalizedLabel;
			}

			try {
				const hostname = new URL(String(url || '').trim()).hostname.toLowerCase().replace(/^www\./, '');
				if (hostname.includes('wikipedia.org')) return 'wikipedia';
				return hostname.split('.')[0] || hostname;
			} catch {
				return 'website';
			}
		}

		function formatSourceUrlForDisplay(url) {
			const normalized = normalizeSourceUrl(url);
			const MAX_DISPLAY_CHARS = 92;
			if (normalized.length <= MAX_DISPLAY_CHARS) {
				return {
					text: normalized,
					truncated: false,
				};
			}

			return {
				text: `${normalized.slice(0, MAX_DISPLAY_CHARS - 3)}...`,
				truncated: true,
			};
		}

		function sanitizeMetadataEntry(rawEntry) {
			if (!rawEntry || typeof rawEntry !== 'object' || !rawEntry.id) return null;

			const fields = Array.isArray(rawEntry.fields)
				? rawEntry.fields
						.map((field) => {
							if (!field || typeof field !== 'object') return null;
							const label = String(field.label || '').trim();
							const value = String(field.value || '').trim();
							const sourceUrl = normalizeSourceUrl(field.sourceUrl);
							if (!label || !value || !isValidSourceUrl(sourceUrl)) return null;
							return {
								key: String(field.key || '').trim(),
								label,
								value,
								sourceUrl,
								sourceLabel: String(field.sourceLabel || '').trim(),
							};
						})
						.filter(Boolean)
				: [];

			const allSources = Array.isArray(rawEntry.allSources)
				? Array.from(
						new Set(
							rawEntry.allSources
								.map((url) => normalizeSourceUrl(url))
								.filter((url) => isValidSourceUrl(url)),
						),
				  )
				: [];

			if (!fields.length && !allSources.length) return null;

			return {
				id: String(rawEntry.id),
				collection: String(rawEntry.collection || ''),
				hymnAbbr: String(rawEntry.hymnAbbr || '').trim(),
				number: String(rawEntry.number || '').trim(),
				fields,
				allSources,
			};
		}

		async function ensureHymnMetadataLoaded() {
			if (hymnMetadataById.size > 0) return;
			if (hymnMetadataLoadPromise) {
				await hymnMetadataLoadPromise;
				return;
			}

			hymnMetadataLoadPromise = (async () => {
				const resp = await fetch(HYMN_METADATA_PATH, { cache: 'force-cache' });
				if (!resp.ok) {
					throw new Error('無法載入詩歌資料來源索引');
				}
				const data = await resp.json();
				const items = Array.isArray(data?.items) ? data.items : [];
				for (const rawEntry of items) {
					const entry = sanitizeMetadataEntry(rawEntry);
					if (entry) hymnMetadataById.set(entry.id, entry);
				}
			})();

			try {
				await hymnMetadataLoadPromise;
			} finally {
				hymnMetadataLoadPromise = null;
			}
		}

		function getHymnMetadataById(id) {
			if (!id) return null;
			return hymnMetadataById.get(id) || null;
		}

		function hasHymnMetadata(id) {
			const metadata = getHymnMetadataById(id);
			return Boolean(metadata && Array.isArray(metadata.fields) && metadata.fields.length > 0);
		}

		function shouldShowSongInfoButton(payload) {
			if (!payload?.id) return false;
			if (hymnMetadataById.size === 0) {
				return payload.collection === 'hymn_a';
			}
			return hasHymnMetadata(payload.id);
		}

		function isSongInfoDialogOpen() {
			return Boolean(songInfoDialog && !songInfoDialog.classList.contains('hidden-panel'));
		}

		function closeSongInfoDialog() {
			if (!songInfoDialog) return;
			songInfoDialog.classList.add('hidden-panel');
			songInfoDialog.classList.remove('is-open');
			songInfoDialog.setAttribute('aria-hidden', 'true');
			setSongInfoButtonActiveState(false);
			const buttons = document.querySelectorAll('.song-info-open-btn-floating');
			buttons.forEach((btn) => btn.blur());
		}

		function setSongInfoButtonActiveState(isActive) {
			const buttons = document.querySelectorAll('#song-info-floating-open');
			if (!buttons.length) return;
			buttons.forEach((btn) => {
				btn.classList.toggle('is-active', Boolean(isActive));
				btn.setAttribute('aria-pressed', isActive ? 'true' : 'false');
			});
		}

		function resetSongInfoDialogScrollTop() {
			if (songInfoDialog) songInfoDialog.scrollTop = 0;
			if (songInfoCard) songInfoCard.scrollTop = 0;
		}

		function openSongInfoDialog(payload, metadata) {
			if (!songInfoDialog || !songInfoTitle || !songInfoContent || !payload || !metadata) return;

			const hymnAbbr = metadata.hymnAbbr || convertByLang(getCollectionShortLabel(payload.collection), state.languageMode);
			const number = metadata.number || String(payload.number || '').trim();
			const title = convertByLang(payload.title || '', state.languageMode);
			songInfoTitle.textContent = `${number} ${title}`.trim();
			const reportSongNumber = `${hymnAbbr}${number}`;
			const reportSubject = '平安詩集 - 錯誤回報';
			const reportBody = `${reportSongNumber} - 資料錯誤詳情: `;
			const reportHref = `mailto:hkpec.hymn@gmail.com?subject=${encodeURIComponent(reportSubject)}&body=${encodeURIComponent(reportBody)}`;

			const fieldsHtml = (metadata.fields || [])
				.map((field) => {
					const label = convertByLang(field.label, state.languageMode);
					const value = convertByLang(field.value, state.languageMode);
					const sourceSiteName = getSourceSiteName(field.sourceUrl, field.sourceLabel);
					const sourceBtnText = `${convertByLang('來源', state.languageMode)}: ${sourceSiteName}`;
					const sourceBtn = isValidSourceUrl(field.sourceUrl)
						? `<a class="search-btn subtle song-info-source-btn" href="${escapeHtml(field.sourceUrl)}" target="_blank" rel="noopener noreferrer">${escapeHtml(sourceBtnText)}</a>`
						: '';

					return `
						<section class="song-info-field">
							<div class="song-info-field-header">
								<h4>${escapeHtml(label)}</h4>
								${sourceBtn}
							</div>
							<p>${escapeHtml(value)}</p>
						</section>
					`;
				})
				.join('');

			const sources = Array.from(new Set((metadata.allSources || []).filter((url) => isValidSourceUrl(url))));
			const allSourcesHtml = sources.length
				? `
					<section class="song-info-all-sources">
						<h4>${escapeHtml(convertByLang('資料來源', state.languageMode))}</h4>
						<ul>
							${sources
								.map((url) => {
									const rendered = formatSourceUrlForDisplay(url);
									return `<li><a class="${rendered.truncated ? 'is-truncated' : ''}" href="${escapeHtml(url)}" title="${escapeHtml(url)}" target="_blank" rel="noopener noreferrer">${escapeHtml(rendered.text)}</a></li>`;
								})
								.join('')}
						</ul>
					</section>
				`
				: `<div class="empty-state compact">${escapeHtml(convertByLang('暫未找到可用的公開資料', state.languageMode))}</div>`;
			const disclaimerHtml = `
				<section class="song-info-disclaimer">
					<p>${escapeHtml(convertByLang('資料已經初步核對，但仍可能存在錯誤。如發現資料有誤，請點擊下方按鈕回報，謝謝。', state.languageMode))}</p>
					<a class="search-btn subtle song-info-report-btn" href="${escapeHtml(reportHref)}">${escapeHtml(convertByLang('問題回報', state.languageMode))}</a>
				</section>
			`;

