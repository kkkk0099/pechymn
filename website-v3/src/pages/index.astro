		function updateLyricSideNavBounds() {
			if (!lyricViewer) return;
			const stage = lyricViewer.querySelector('.lyric-swipe-stage');
			if (!stage) return;

			const header = stage.querySelector('.lyric-slide-current .lyric-header');
			if (!header) {
				stage.style.removeProperty('--lyric-side-nav-top');
				stage.style.removeProperty('--lyric-side-nav-height');
				return;
			}

			const headerBottom = Math.round(header.getBoundingClientRect().bottom);
			const navTop = Math.max(0, Math.min(window.innerHeight, headerBottom));
			const navHeight = Math.max(0, window.innerHeight - navTop);

			stage.style.setProperty('--lyric-side-nav-top', `${navTop}px`);
			stage.style.setProperty('--lyric-side-nav-height', `${navHeight}px`);
		}

		function updateLyricStageHeight(target = 'current', immediate = false) {
			if (!lyricViewer) return;
			const stage = lyricViewer.querySelector('.lyric-swipe-stage');
			if (!stage) return;

			const selector = target === 'prev'
				? '.lyric-slide-prev'
				: target === 'next'
					? '.lyric-slide-next'
					: '.lyric-slide-current';
			const slide = stage.querySelector(selector);
			const measuredRaw = Math.ceil(slide?.getBoundingClientRect?.().height || slide?.scrollHeight || stage.scrollHeight || 0);
			const minStageHeight = Math.max(180, Math.floor((window.innerHeight || 640) * 0.35));
			const measured = Math.max(minStageHeight, measuredRaw);

			if (immediate) {
				stage.classList.add('height-no-transition');
				stage.style.setProperty('--lyric-stage-height', `${measured}px`);
				requestAnimationFrame(() => {
					stage.classList.remove('height-no-transition');
				});
				return;
			}

			stage.style.setProperty('--lyric-stage-height', `${measured}px`);
		}

		function resetLyricSwipePosition() {
			if (!lyricViewer) return;
			lyricViewer.style.setProperty('--lyric-swipe-offset', '0px');
			lyricViewer.classList.remove('swipe-dragging', 'swipe-animating');
			lyricSwipeState.pointerId = null;
			lyricSwipeState.horizontal = false;
			lyricSwipeState.offsetX = 0;
		}

		function getAdjacentLyric(direction) {
			const navInfo = getLyricNavInfo(currentLyricId, lyricNavSource);
			if (direction === 'prev') {
				return navInfo.prevItem || null;
			}
			return navInfo.nextItem || null;
		}

		function animateLyricSwipe(direction) {
			if (lyricSwipeAnimating) return;
			const targetItem = getAdjacentLyric(direction);
			if (!targetItem) return;

			const stage = lyricViewer.querySelector('.lyric-swipe-stage');
			if (!stage) {
				openLyric(targetItem, { source: lyricNavSource, rebuildNavSnapshot: false });
				return;
			}

			updateLyricStageHeight(direction === 'next' ? 'next' : 'prev');

			lyricSwipeAnimating = true;
			const width = Math.max(1, stage.getBoundingClientRect().width);
			const toOffset = direction === 'next' ? -width : width;

			lyricViewer.classList.add('swipe-animating');
			lyricViewer.style.setProperty('--lyric-swipe-offset', `${toOffset}px`);

			const onEnd = () => {
				stage.removeEventListener('transitionend', onEnd);
				lyricSwipeAnimating = false;
				openLyric(targetItem, { source: lyricNavSource, rebuildNavSnapshot: false });
			};

			stage.addEventListener('transitionend', onEnd, { once: true });
		}

		function handleLyricSwipePointerDown(event) {
			if (event.pointerType !== 'touch' || lyricSwipeAnimating) return;
			if (!lyricOverlay || !lyricOverlay.classList.contains('overlay-visible')) return;
			if (!currentLyricId) return;
			if (!lyricViewer?.querySelector('.lyric-swipe-stage')) return;
			if (!event.target.closest('.lyric-overlay-card')) return;
			if (event.target.closest('#song-info-dialog')) return;
			if (event.target.closest('button, a, input, select, textarea')) return;
			if (lyricOverlayCard?.setPointerCapture) {
				try {
					lyricOverlayCard.setPointerCapture(event.pointerId);
				} catch {
					// Ignore platforms that reject capture for this pointer state.
				}
			}

			lyricSwipeState.pointerId = event.pointerId;
			lyricSwipeState.startX = event.clientX;
			lyricSwipeState.startY = event.clientY;
			lyricSwipeState.offsetX = 0;
			lyricSwipeState.horizontal = false;
		}

		function handleLyricSwipePointerMove(event) {
			if (lyricSwipeState.pointerId !== event.pointerId || lyricSwipeAnimating) return;
			const dx = event.clientX - lyricSwipeState.startX;
			const dy = event.clientY - lyricSwipeState.startY;
			const navInfo = getLyricNavInfo(currentLyricId, lyricNavSource);
			const canSwipePrev = Boolean(navInfo?.prevItem);
			const canSwipeNext = Boolean(navInfo?.nextItem);

			if (!lyricSwipeState.horizontal) {
				if (Math.abs(dx) < 10) return;
				if (Math.abs(dx) <= Math.abs(dy)) {
					lyricSwipeState.pointerId = null;
					return;
				}
				if ((dx > 0 && !canSwipePrev) || (dx < 0 && !canSwipeNext)) {
					lyricSwipeState.pointerId = null;
					lyricSwipeState.horizontal = false;
					lyricSwipeState.offsetX = 0;
					lyricViewer.style.setProperty('--lyric-swipe-offset', '0px');
					return;
				}
				lyricSwipeState.horizontal = true;
				lyricViewer.classList.add('swipe-dragging');
			}

			event.preventDefault();
			const blockedDx = (dx > 0 && !canSwipePrev) || (dx < 0 && !canSwipeNext) ? 0 : dx;
			lyricSwipeState.offsetX = blockedDx;
			lyricViewer.style.setProperty('--lyric-swipe-offset', `${blockedDx}px`);
		}

		function handleLyricSwipePointerEnd(event) {
			if (lyricSwipeState.pointerId !== event.pointerId) return;
			if (lyricOverlayCard?.releasePointerCapture) {
				try {
					lyricOverlayCard.releasePointerCapture(event.pointerId);
				} catch {
					// Ignore if pointer capture is already released.
				}
			}
			const stage = lyricViewer.querySelector('.lyric-swipe-stage');
			const width = stage ? Math.max(1, stage.getBoundingClientRect().width) : 1;
			const threshold = Math.max(60, width * 0.18);
			const offset = lyricSwipeState.offsetX;

			lyricSwipeState.pointerId = null;
			lyricViewer.classList.remove('swipe-dragging');

			if (!lyricSwipeState.horizontal) {
				resetLyricSwipePosition();
				return;
			}

			lyricSwipeState.horizontal = false;

			if (Math.abs(offset) < threshold) {
				lyricViewer.classList.add('swipe-animating');
				lyricViewer.style.setProperty('--lyric-swipe-offset', '0px');
				const onEnd = () => {
					if (stage) {
						stage.removeEventListener('transitionend', onEnd);
					}
					lyricViewer.classList.remove('swipe-animating');
				};
				if (stage) {
					stage.addEventListener('transitionend', onEnd, { once: true });
				} else {
					onEnd();
				}
				return;
			}

			if (offset < 0) {
				animateLyricSwipe('next');
			} else {
				animateLyricSwipe('prev');
			}
		}

		function stopActiveAudio() {
			if (!activeAudio) {
				updateAudioControlsUI();
				return;
			}
			try {
				activeAudio.pause();
				activeAudio.currentTime = 0;
				activeAudio.removeAttribute('src');
				activeAudio.load();
			} catch {
				// Ignore audio stop failures.
			}
			if (activeAudioObjectUrl) {
				URL.revokeObjectURL(activeAudioObjectUrl);
				activeAudioObjectUrl = '';
			}
			activeAudio = null;
			activeAudioPath = '';
			updateAudioControlsUI();
		}

		function loadAudioCacheMeta() {
			try {
				const raw = localStorage.getItem(AUDIO_CACHE_META_KEY);
				if (!raw) return { totalBytes: 0, entries: {} };
				const parsed = JSON.parse(raw);
				if (!parsed || typeof parsed !== 'object') return { totalBytes: 0, entries: {} };
				return {
					totalBytes: Number(parsed.totalBytes) || 0,
					entries: parsed.entries && typeof parsed.entries === 'object' ? parsed.entries : {},
				};
			} catch {
				return { totalBytes: 0, entries: {} };
			}
		}

		function saveAudioCacheMeta(meta) {
			localStorage.setItem(AUDIO_CACHE_META_KEY, JSON.stringify(meta));
		}

		async function enforceAudioCacheLimit(cache, meta) {
			const rows = Object.entries(meta.entries).map(([url, info]) => ({
				url,
				size: Number(info.size) || 0,
				lastAccess: Number(info.lastAccess) || 0,
			}));

			rows.sort((a, b) => a.lastAccess - b.lastAccess);

			while (
				rows.length > AUDIO_CACHE_MAX_ENTRIES ||
				meta.totalBytes > AUDIO_CACHE_MAX_BYTES
			) {
				const oldest = rows.shift();
				if (!oldest) break;
				await cache.delete(oldest.url);
				meta.totalBytes = Math.max(0, meta.totalBytes - oldest.size);
				delete meta.entries[oldest.url];
			}
		}

		async function resolveAudioSource(pathValue) {
			const normalized = toBasePath(pathValue);
			if (!('caches' in window)) {
				return { src: normalized, fromCache: false };
			}

			const cache = await caches.open(AUDIO_CACHE_NAME);
			const meta = loadAudioCacheMeta();

			const cachedResp = await cache.match(normalized);
			if (cachedResp) {
				const blob = await cachedResp.blob();
				meta.entries[normalized] = {
					size: blob.size,
					lastAccess: Date.now(),
				};
				saveAudioCacheMeta(meta);
				return {
					src: URL.createObjectURL(blob),
					fromCache: true,
				};
			}

			const networkResp = await fetch(normalized, { cache: 'no-store' });
			if (!networkResp.ok) {
				throw new Error(`Audio fetch failed: ${networkResp.status}`);
			}

			const blob = await networkResp.clone().blob();
			await cache.put(normalized, networkResp.clone());

			meta.entries[normalized] = {
				size: blob.size,
				lastAccess: Date.now(),
			};
			meta.totalBytes = Object.values(meta.entries).reduce((sum, item) => sum + (Number(item.size) || 0), 0);
			await enforceAudioCacheLimit(cache, meta);
			saveAudioCacheMeta(meta);

			return {
				src: URL.createObjectURL(blob),
				fromCache: false,
			};
		}

		async function playAudioOnDemand(pathValue) {
			if (!pathValue) return;
			const normalized = normalizeAudioPath(pathValue);

			if (activeAudioPath !== normalized) {
				stopActiveAudio();
				activeAudio = new Audio();
				activeAudio.preload = 'metadata';
				const resolved = await resolveAudioSource(pathValue);
				activeAudio.src = resolved.src;
				activeAudioObjectUrl = resolved.src.startsWith('blob:') ? resolved.src : '';
				activeAudioPath = normalized;
				bindActiveAudioEvents(pathValue);
			} else if (activeAudio && !activeAudio.paused) {
				activeAudio.pause();
				updateAudioControlsUI(pathValue);
				return;
			}

			try {
				await activeAudio.play();
				updateAudioControlsUI(pathValue);
			} catch (error) {
				const timeLabel = lyricViewer.querySelector('#audio-time');
				if (timeLabel) {
					timeLabel.textContent = `播放失敗`;
				}
			}
		}

		async function openLyric(item, options = {}) {
			try {
				clearHistoryAutoAddTimer();
				closeSongInfoDialog();
				const source = options.source || lyricNavSource || 'search';
				lyricNavSource = source;
				if (source !== 'search') {
					syncFiltersForBrowsingItem(item, {
						useDefaultGroup: options.useDefaultGroup === true || source === 'bookmarks' || source === 'history',
					});
				} else {
					syncCollectionForSearchResult(item);
				}
				if (options.rebuildNavSnapshot !== false) {
					const liveNavItems = getLyricNavItemsFromLiveSource(source);
					lyricNavSnapshotSource = source;
					lyricNavSnapshotIds = liveNavItems.map((entry) => entry.id);
				}
				const navInfoBeforeLoad = getLyricNavInfo(item.id, lyricNavSource);

				closeSettingsPanel();
				openLyricOverlay();
				lyricViewer.innerHTML = '<div class="empty-state">&nbsp;</div>';
				lyricViewer.dataset.currentId = '';
				setResultActive(item.id);
				stopActiveAudio();

				const payloadPromise = loadLyricPayloadByItem(item);
				const prevPromise = navInfoBeforeLoad.prevItem
					? loadLyricPayloadByItem(navInfoBeforeLoad.prevItem).catch(() => null)
					: Promise.resolve(null);
				const nextPromise = navInfoBeforeLoad.nextItem
					? loadLyricPayloadByItem(navInfoBeforeLoad.nextItem).catch(() => null)
					: Promise.resolve(null);

				const payload = await payloadPromise;
				const [prevPayload, nextPayload] = await Promise.all([prevPromise, nextPromise]);

				currentLyricId = payload.id;
				state.lastViewed = payload.id;
				saveState();

				renderLyric(payload, navInfoBeforeLoad, { prevPayload, nextPayload });
				resetLyricSwipePosition();
				resetLyricOverlayScroll();
				scheduleHistoryAutoAdd(payload);
			} catch (error) {
				clearHistoryAutoAddTimer();
				lyricViewer.innerHTML = `<div class="empty-state">${escapeHtml(String(error))}</div>`;
				resetLyricOverlayScroll();
			}
		}

		function syncCollectionForSearchResult(item) {
			if (!item || !GROUP_DEFINITIONS[item.collection] || !isCollectionAllowed(item.collection)) return;
			if (state.filters.collection === item.collection) return;

			state.filters.collection = item.collection;
			state.filters.groupKey = findGroupKeyForItem(item) || getDefaultGroupKey(item.collection);
			renderQuickbar();
			renderGroupList();
			saveState();
		}

		function doSearch(forceAllGroup = false, closeSettings = true, autoOpenSingleResult = false) {
			if (closeSettings) {
				closeSettingsPanel();
			}
			resultList.scrollTop = 0;

			if (forceAllGroup) {
				const defaultGroupKey = getDefaultGroupKey(getActiveCollection());
				if (defaultGroupKey && state.filters.groupKey !== defaultGroupKey) {
					state.filters.groupKey = defaultGroupKey;
					renderGroupList();
					saveState();
				}
			}

			const raw = input.value.trim();
			const queryText = buildSearchQueryText(raw);
			const numberQuery = parseSongNumberToken(queryText);

			if (!numberQuery && raw) {
				const baseItems = indexItems.filter((item) => isCollectionAllowed(item.collection));
				const tokens = foldVariantsForSearch(normalize(queryText))
					.split(' ')
					.filter(Boolean);

				const scored = [];
				for (const item of baseItems) {
					let score = 0;
					const target = item.searchTargetFolded || '';
					let matchedAll = true;

					for (const token of tokens) {
						if (!target.includes(token)) {
							matchedAll = false;
							break;
						}

						if ((item.normalizedTitleFolded || '').includes(token)) score += 5;
						if ((item.normalizedNumberFolded || '').includes(token)) score += 8;
						if ((item.normalizedLyricsFolded || '').includes(token)) score += 1;
					}

					if (matchedAll) {
						scored.push({ item, score });
					}
				}

				scored.sort((a, b) => {
					if (b.score !== a.score) return b.score - a.score;
					return a.item.id.localeCompare(b.item.id);
				});

				currentResults = scored.slice(0, 120).map((entry) => entry.item);
				renderResults(currentResults);
				if (autoOpenSingleResult && currentResults.length === 1) {
					syncCollectionForSearchResult(currentResults[0]);
					openLyric(currentResults[0], { source: 'search' });
				}
				return;
			}

			if (!getActiveGroup()) {
				currentResults = [];
				resultList.innerHTML = '<div class="empty-state">請先選擇分類，再顯示搜尋結果。</div>';
				return;
			}

			const baseItems = getItemsInActiveGroup();
			if (!raw) {
				currentResults = baseItems;
				renderResults(currentResults);
				return;
			}

			if (numberQuery) {
				currentResults = baseItems.filter((item) => {
					const itemNumber = parseSongNumberToken(item.number);
					if (!itemNumber) return false;

					if (numberQuery.suffix) {
						return itemNumber.base === numberQuery.base && itemNumber.suffix === numberQuery.suffix;
					}

					return itemNumber.base === numberQuery.base;
				});
				renderResults(currentResults);
				if (autoOpenSingleResult && currentResults.length === 1) {
					syncCollectionForSearchResult(currentResults[0]);
					openLyric(currentResults[0], { source: 'search' });
				}
				return;
			}
		}

		resultList.addEventListener('click', (event) => {
			const button = event.target.closest('.result-item');
			if (!button) return;
			const id = button.getAttribute('data-id');
			const item = currentResults.find((entry) => entry.id === id);
			if (item) {
				syncCollectionForSearchResult(item);
				openLyric(item, { source: 'search' });
			}
		});

