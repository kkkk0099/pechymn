		document.addEventListener('keydown', (event) => {
			if (event.key === 'Escape') {
				if (isSongInfoDialogOpen()) {
					closeSongInfoDialog();
					return;
				}
				if (lyricOverlay.classList.contains('overlay-visible')) {
					closeLyricOverlay();
					return;
				}
				if (bookmarkOverlay.classList.contains('overlay-visible')) {
					closeBookmarkOverlay();
				}
				return;
			}

			if (!lyricOverlay.classList.contains('overlay-visible')) return;
			if (event.key === 'ArrowLeft') {
				event.preventDefault();
				animateLyricSwipe('prev');
			} else if (event.key === 'ArrowRight') {
				event.preventDefault();
				animateLyricSwipe('next');
			}
		});

		lyricViewer.addEventListener('click', async (event) => {
			if (event.target.closest('#lyric-prev')) {
				animateLyricSwipe('prev');
				return;
			}

			if (event.target.closest('#lyric-next')) {
				animateLyricSwipe('next');
				return;
			}

			const audioPlayBtn = event.target.closest('#audio-play');
			if (audioPlayBtn) {
				const audioPath = audioPlayBtn.getAttribute('data-audio-path');
				playAudioOnDemand(audioPath);
				return;
			}

			if (event.target.closest('#audio-stop')) {
				stopActiveAudio();
				return;
			}

			if (event.target.closest('#song-info-floating-open')) {
				if (!currentLyricId) return;
				const payload = lyricCacheRaw.get(currentLyricId);
				if (!payload) return;

				if (isSongInfoDialogOpen()) {
					closeSongInfoDialog();
					return;
				}

				try {
					await ensureHymnMetadataLoaded();
				} catch {
					return;
				}

				const metadata = getHymnMetadataById(currentLyricId) || {
					id: payload.id,
					collection: payload.collection,
					hymnAbbr: getCollectionShortLabel(payload.collection),
					number: String(payload.number || '').trim(),
					fields: [],
					allSources: [],
				};
				openSongInfoDialog(payload, metadata);
				return;
			}

			const target = event.target.closest('#bookmark-toggle');
			if (!target) return;
			const id = target.getAttribute('data-id');
			if (!id) return;

			const item = findItemById(id);
			if (!item) return;

			if (isBookmarked(id)) {
				state.bookmarks = state.bookmarks.filter((entry) => entry.id !== id);
			} else {
				state.bookmarks = upsertEntry(state.bookmarks, {
					id,
					title: item.title,
					number: item.number,
					collection: item.collection,
				});
			}

			saveState();
			renderShelves();
			const raw = lyricCacheRaw.get(id);
			if (raw) {
				const navInfo = getLyricNavInfo(id, lyricNavSource);
				const prevPayload = navInfo.prevItem ? lyricCacheRaw.get(navInfo.prevItem.id) || null : null;
				const nextPayload = navInfo.nextItem ? lyricCacheRaw.get(navInfo.nextItem.id) || null : null;
				renderLyric(raw, navInfo, { prevPayload, nextPayload });
				resetLyricSwipePosition();
			}
		});

		songInfoClose?.addEventListener('click', () => {
			closeSongInfoDialog();
		});

		songInfoDialog?.addEventListener('click', (event) => {
			if (event.target === songInfoDialog) {
				closeSongInfoDialog();
			}
		});

		function attachShelfHandler(container, listName) {
			container.addEventListener('click', (event) => {
				const btn = event.target.closest('button');
				if (!btn) return;
				const id = btn.getAttribute('data-id');
				const action = btn.getAttribute('data-action');
				if (!id || !action) return;

				if (action === 'remove') {
					state[listName] = state[listName].filter((entry) => entry.id !== id);
					saveState();
					renderShelves();
					return;
				}

				const item = findItemById(id);
				if (item) {
					if (!isCollectionAllowed(item.collection)) return;
					setActiveCollection(item.collection);
					openLyric(item, {
						source: listName,
						useDefaultGroup: listName === 'bookmarks' || listName === 'history',
					});
				}
			});
		}

		attachShelfHandler(bookmarkList, 'bookmarks');
		attachShelfHandler(historyList, 'history');

		searchBtn.addEventListener('click', () => {
			executeSearchWithCurrentInput();
		});

		input.addEventListener('keydown', (event) => {
			if (event.key === 'Enter') {
				event.preventDefault();
				executeSearchWithCurrentInput();
				if (window.matchMedia('(pointer: coarse)').matches) {
					input.blur();
				}
			}
		});

		input.addEventListener('focus', () => {
			renderSearchHistoryOverlay();
		});

		input.addEventListener('input', () => {
			if (document.activeElement !== input) return;
			renderSearchHistoryOverlay();
		});

		document.addEventListener('pointerdown', (event) => {
			if (!searchRow) return;
			if (searchRow.contains(event.target)) return;
			hideSearchHistoryOverlay();
		});

		searchHistoryList.addEventListener('click', (event) => {
			const removeBtn = event.target.closest('.search-history-remove');
			if (removeBtn) {
				const queryToRemove = String(removeBtn.getAttribute('data-query') || '').trim().toLowerCase();
				if (!queryToRemove) return;
				state.searchHistory = sanitizeSearchHistory(state.searchHistory).filter(
					(entry) => String(entry ?? '').trim().toLowerCase() !== queryToRemove,
				);
				saveState();
				renderSearchHistoryOverlay();
				return;
			}

			const item = event.target.closest('.search-history-item');
			if (!item) return;
			const query = item.getAttribute('data-query') || '';
			input.value = query;
			executeSearchWithCurrentInput();
		});

		toggleSettingsBtn.addEventListener('click', () => {
			if (settingsPanel.classList.contains('is-open')) {
				closeSettingsPanel();
				return;
			}
			openSettingsPanel();
		});

		settingsCloseBtn.addEventListener('click', () => {
			closeSettingsPanel();
		});

		settingsPanel.addEventListener('transitionrun', (event) => {
			if (event.propertyName !== 'max-height') return;
			startSettingsLayoutSync();
		});

		settingsPanel.addEventListener('transitionend', (event) => {
			if (event.propertyName !== 'max-height') return;
			updateResultViewportLayout();
		});

		window.addEventListener('resize', () => {
			if (settingsPanel.classList.contains('is-open')) {
				updateSettingsPanelOpenHeight();
			}
			updateResultViewportLayout();
			updateLyricStageHeight('current', true);
			updateLyricSideNavBounds();
			renderQuickbar();
		});

		settingFontSize.addEventListener('input', () => {
			state.settings.fontSizeMode = 'manual';
			state.settings.fontSize = Math.min(
				FONT_SIZE_MAX,
				Math.max(FONT_SIZE_MIN, Number.parseInt(settingFontSize.value, 10) || getResponsiveDefaultFontSize()),
			);
			applyStateToUI();
			updateLyricStageHeight('current', true);
			updateLyricSideNavBounds();
			saveState();
		});

		settingLanguage.addEventListener('change', () => {
			state.languageMode = settingLanguage.value;
			applyStateToUI();
			renderGroupList();
			doSearch(false, false);
			const raw = lyricCacheRaw.get(currentLyricId);
			if (raw) {
				const navInfo = getLyricNavInfo(currentLyricId, lyricNavSource);
				const prevPayload = navInfo.prevItem ? lyricCacheRaw.get(navInfo.prevItem.id) || null : null;
				const nextPayload = navInfo.nextItem ? lyricCacheRaw.get(navInfo.nextItem.id) || null : null;
				const metadata = getHymnMetadataById(currentLyricId);
				renderLyric(raw, navInfo, { prevPayload, nextPayload });
				resetLyricSwipePosition();
				updateLyricStageHeight('current', true);
				if (isSongInfoDialogOpen() && metadata) {
					openSongInfoDialog(raw, metadata);
				}
			}
			renderShelves();
			saveState();
		});

		function applyCongregationChange(nextCongregation) {
			const normalized = normalizeCongregation(nextCongregation);
			state.settings.congregation = normalized;
			syncHashByCongregation(normalized);
			state.filters.collection = 'hymn_a';
			state.filters.groupKey = getDefaultGroupKey('hymn_a');
			input.value = '';
			hideSearchHistoryOverlay();
			stopActiveAudio();
			closeLyricOverlay({ immediate: true });
			closeBookmarkOverlay({ immediate: true });
			currentLyricId = '';
			applyStateToUI();
			renderQuickbar();
			renderGroupList();
			renderShelves();
			doSearch(false, false);
			updateResultViewportLayout();
			saveState();
		}

		for (const option of congregationRadioOptions) {
			option.addEventListener('change', () => {
				if (!option.checked) return;
				applyCongregationChange(option.value);
			});
		}

		// Initialize congregation prompt shown to first-time visitors.
		function initCongregationPrompt() {
			const PROMPT_KEY = 'hymn_congregation_prompt_shown_v1';
			if (typeof localStorage === 'undefined') return;
			if (localStorage.getItem(PROMPT_KEY)) return;
			const promptEl = document.getElementById('congregation-prompt');
			if (!promptEl) return;
			promptEl.classList.remove('hidden');
			promptEl.classList.add('is-visible');
			promptEl.setAttribute('aria-hidden', 'false');
			let autoTimer = null;

			function closePrompt(selectDefault = true) {
				if (!promptEl) return;
				promptEl.classList.remove('is-visible');
				promptEl.setAttribute('aria-hidden', 'true');
				localStorage.setItem(PROMPT_KEY, '1');
				if (autoTimer) {
					clearTimeout(autoTimer);
					autoTimer = null;
				}
				if (selectDefault) applyCongregationChange(CONGREGATION_OTHER);
				setTimeout(() => {
					if (promptEl.matches('.is-visible')) return;
					promptEl.classList.add('hidden');
				}, 240);
			}

			const buttons = Array.from(promptEl.querySelectorAll('button[data-congreg]'));
			for (const btn of buttons) {
				btn.addEventListener('click', () => {
					const val = btn.getAttribute('data-congreg') || CONGREGATION_OTHER;
					applyCongregationChange(val);
					closePrompt(false);
				});
			}
		}

		lyricOverlayCard?.addEventListener('pointerdown', handleLyricSwipePointerDown);
		lyricOverlayCard?.addEventListener('pointermove', handleLyricSwipePointerMove);
		lyricOverlayCard?.addEventListener('pointerup', handleLyricSwipePointerEnd);
		lyricOverlayCard?.addEventListener('pointercancel', handleLyricSwipePointerEnd);

		(async function bootstrap() {
			loadState();
			const congregationFromHash = getCongregationFromHash();
			if (congregationFromHash) {
				state.settings.congregation = congregationFromHash;
			} else {
				syncHashByCongregation(normalizeCongregation(state.settings.congregation));
			}
			sanitizeFiltersForCongregation();
			if (!getActiveGroup()) {
				state.filters.groupKey = getDefaultGroupKey(getActiveCollection());
			}
			document.body.classList.add('has-quickbar');
			applyStateToUI();
			// Show congregation prompt for first-time visitors
			initCongregationPrompt();
			updateResultViewportLayout();
			renderShelves();
			renderQuickbar();
			renderGroupList();
			resultList.innerHTML = '<div class="empty-state">正在載入詩歌資料...</div>';

			try {
				const resp = await fetch(toBasePath('data/search-index-lite.json'), { cache: 'force-cache' });
				if (!resp.ok) {
					throw new Error('無法載入全文索引');
				}
				const data = await resp.json();
				indexItems = (data.items || []).map((item) => {
					const normalizedNumber = String(item.normalizedNumber || '');
					const normalizedTitle = String(item.normalizedTitle || '');
					const normalizedLyrics = String(item.normalizedLyrics || '');
					return {
						...item,
						normalizedNumberFolded: foldVariantsForSearch(normalizedNumber),
						normalizedTitleFolded: foldVariantsForSearch(normalizedTitle),
						normalizedLyricsFolded: foldVariantsForSearch(normalizedLyrics),
						searchTargetFolded: foldVariantsForSearch(`${normalizedNumber} ${normalizedTitle} ${normalizedLyrics}`),
					};
				});
				syncShelfEntriesFromIndex();
				renderShelves();
				renderGroupList();
				doSearch();
				updateResultViewportLayout();

				saveState();
			} catch (error) {
				resultList.innerHTML = '<div class="empty-state">請先執行 npm run generate:data 產生索引。</div>';
			}
		})();
	</script>
</BaseLayout>
