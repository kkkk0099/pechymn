---
/// <reference types="node" />
import fs from 'node:fs';
import path from 'node:path';
import { fileURLToPath } from 'node:url';
import BaseLayout from '../layouts/BaseLayout.astro';

const baseUrl = import.meta.env.BASE_URL;
const toBase = (path = '') => `${baseUrl}${String(path).replace(/^\/+/, '')}`;

const __filename = fileURLToPath(import.meta.url);
const __dirname = path.dirname(__filename);
const projectRoot = path.resolve(__dirname, '../..');

function loadJsonOrNull(fileRel: string): any | null {
  const filePath = path.join(projectRoot, fileRel);
  if (!fs.existsSync(filePath)) return null;
  try {
    return JSON.parse(fs.readFileSync(filePath, 'utf8'));
  } catch {
    return null;
  }
}

const audit = loadJsonOrNull('public/data/asset-audit-report.json');
const lighthouse = loadJsonOrNull('public/data/lighthouse-mobile-baseline.json');
const sprint5 = loadJsonOrNull('public/data/sprint5-verification-report.json');

const topAssets: Array<{ path: string; type: string; sizeLabel: string }> = audit?.top20BySize ?? [];
const summary = audit?.summary;
const lighthouseStatus = lighthouse?.status ?? 'ok';
const categories = lighthouse?.categories ?? null;
const sprint5Summary = sprint5?.summary ?? null;
const sprint5Checks: Array<{ id: string; status: string }> = sprint5?.automatedChecks ?? [];
---

<BaseLayout title="平安詩集 | 資產摘要" description="Sprint 4-5 資產審計、Lighthouse 與上線驗收報告。">
  <section class="card header">
    <span class="badge">Sprint 4-5</span>
    <h1>資產與效能摘要</h1>
    <p>此頁彙整 asset audit、Lighthouse mobile 基線與 Sprint 5 驗收狀態，供部署前檢查。</p>
    <div class="nav-row">
      <a class="nav-chip" href={toBase('')}>返回主頁</a>
      <a class="nav-chip" href={toBase('news/')}>消息公告</a>
      <a class="nav-chip" href={toBase('privacy/')}>隱私政策</a>
    </div>
  </section>

  <section class="grid single">
    <article class="card tile">
      <h2>Asset Audit</h2>
      {summary ? (
        <ul>
          <li>總檢查檔案: {summary.totalInspected}</li>
          <li>大型資產(>200KB): {summary.largeAssets}</li>
          <li>大型圖片: {summary.largeImages}</li>
          <li>JSON 檔案數: {summary.byType?.json?.count ?? 0}</li>
        </ul>
      ) : (
        <div class="empty-state compact">尚未找到資產審計報告。請執行 npm run audit:assets。</div>
      )}
    </article>

    <article class="card tile">
      <h2>Lighthouse Mobile Baseline</h2>
      {lighthouse ? (
        lighthouseStatus === 'unavailable' ? (
          <div class="empty-state compact">{lighthouse.reason || lighthouse.message || '目前環境無法執行 Lighthouse。'}</div>
        ) : (
          <ul>
            <li>Performance: {categories?.performance ?? '-'}</li>
            <li>Accessibility: {categories?.accessibility ?? '-'}</li>
            <li>Best Practices: {categories?.bestPractices ?? '-'}</li>
            <li>SEO: {categories?.seo ?? '-'}</li>
          </ul>
        )
      ) : (
        <div class="empty-state compact">尚未找到 Lighthouse 報告。請執行 npm run lighthouse:mobile。</div>
      )}
    </article>

    <article class="card tile">
      <h2>Sprint 5 Verification</h2>
      {sprint5 ? (
        <>
          <ul>
            <li>整體狀態: {sprint5Summary?.overall ?? '-'}</li>
            <li>自動檢查: {sprint5Summary?.automatedChecks ?? '-'}</li>
            <li>實機檢查: {sprint5Summary?.manualDeviceChecks ?? '-'}</li>
          </ul>
          <p class="panel-subtitle">Automated checks</p>
          <ul>
            {sprint5Checks.map((check) => (
              <li>{check.id}: {check.status}</li>
            ))}
          </ul>
        </>
      ) : (
        <div class="empty-state compact">尚未找到 Sprint 5 驗收報告。</div>
      )}
    </article>

    <article class="card tile">
      <h2>Top Assets</h2>
      {topAssets.length ? (
        <div style="overflow:auto;">
          <table style="width:100%; border-collapse:collapse;">
            <thead>
              <tr>
                <th style="text-align:left; border-bottom:1px solid #d8b987; padding:0.4rem;">Path</th>
                <th style="text-align:left; border-bottom:1px solid #d8b987; padding:0.4rem;">Type</th>
                <th style="text-align:left; border-bottom:1px solid #d8b987; padding:0.4rem;">Size</th>
              </tr>
            </thead>
            <tbody>
              {topAssets.map((row) => (
                <tr>
                  <td style="padding:0.35rem; border-bottom:1px solid rgba(216,185,135,0.45);">{row.path}</td>
                  <td style="padding:0.35rem; border-bottom:1px solid rgba(216,185,135,0.45);">{row.type}</td>
                  <td style="padding:0.35rem; border-bottom:1px solid rgba(216,185,135,0.45);">{row.sizeLabel}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      ) : (
        <div class="empty-state compact">尚未有資產列表。</div>
      )}
    </article>
  </section>
</BaseLayout>
